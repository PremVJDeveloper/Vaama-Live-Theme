{% comment %}
  Snippet: gpe-product-details.liquid
  Renders: Product Description + Diamond Details + Gold Details (static boxes, no accordion)
{% endcomment %}

{% capture 'variant_meta_fields' %}
  {% for variant in product.variants %}
    {% if variant.metafields.DI-GoldPrice.variant_config != blank %}
      {{ variant.id | json }}: {{ variant.metafields.DI-GoldPrice.variant_config }} {% unless forloop.last %},{% endunless %}
    {% endif %}
  {% endfor %}
{% endcapture %}

{% capture 'variants' %}
  {% for variant in product.variants %}
    {{ variant.id }}: {{ variant | json }} {% unless forloop.last %},{% endunless %}
  {% endfor %}
{% endcapture %}

<div id="gpd-container">
  <span class="gpd-accordion-title">Product Details</span>

  <!-- Product Description -->
  <p class="gpd-description">{{ product.description | strip_html }}</p>

  <!-- Diamond Details Box -->
  <div class="gpd-box" id="gpd-diamond-box" style="display:none;">
    <div class="gpd-box-header-row">
      <span class="gpd-box-title">Diamond Details:</span>
      <div class="gpd-box-header-cols">
        <span class="gpd-th">No. of Diamonds:</span>
        <span class="gpd-th">Weight</span>
      </div>
    </div>
    <div class="gpd-box-divider"></div>
    <div id="gpd-diamond-rows"></div>
  </div>

  <!-- Gold Details Box -->
  <div class="gpd-box" id="gpd-gold-box" style="display:none;">
    <div class="gpd-box-title" style="margin-bottom:10px;">Gold Details:</div>
    <div class="gpd-box-divider"></div>
    <table class="gpd-detail-table" id="gpd-gold-table"><tbody></tbody></table>
  </div>

</div>

<script>
  var gpdVariantConfigs = { {{ variant_meta_fields }} };
  var gpdVariants       = { {{ variants }} };
  var gpdMetalConfig    = {{ shop.metafields.DI-GoldPrice.metal_prices }};
  var gpdStonePricings  = {{ shop.metafields.DI-GoldPrice.stone_pricing | default: "[]" }} || [];

  /* ── Initial render ── */
  var gpdFirstVariantId = {{ product.selected_or_first_available_variant.id }};
  if (gpdVariantConfigs && gpdVariantConfigs[gpdFirstVariantId]) {
    gpdUpdate(gpdFirstVariantId);
  }

  /* ── Listen for variant change ── */
  document.addEventListener('change', function () {
    var url       = new URL(document.URL);
    var variantId = url.searchParams.get('variant');
    if (variantId && !isNaN(variantId) && gpdVariantConfigs && gpdVariantConfigs[variantId]) {
      gpdUpdate(variantId);
    } else if (variantId) {
      document.getElementById('gpd-diamond-box').style.display = 'none';
      document.getElementById('gpd-gold-box').style.display = 'none';
    }
  });

  /* ── Main update ── */
  function gpdUpdate(variantId) {
    var cfg = gpdVariantConfigs[variantId];
    if (!cfg) return;

    /* ---------- DIAMOND DETAILS ----------
       Each advanced_stone_config entry = its own row.
       Diamonds with different weight = different row (no grouping by shape).
       sc.stone_weight = TOTAL weight for all pieces in that entry — show directly, NEVER divide.
    ------------------------------------------------------------ */
    var hasDiamonds = false;
    var html = '';
    var rowIndex = 0;

    if (cfg.advanced_stone_config && cfg.advanced_stone_config.length > 0) {
      for (var i = 0; i < cfg.advanced_stone_config.length; i++) {
        var sc = cfg.advanced_stone_config[i];
        if (sc.stone_type.toLowerCase() !== 'diamond') continue;

        hasDiamonds = true;

        /* Get pricing title from shopStonePricings (e.g. "Marquise- EF VVS") */
        var pricingTitle = gpdFetchTitle(sc) || (sc.shape || 'Diamond');
        pricingTitle = pricingTitle.charAt(0).toUpperCase() + pricingTitle.slice(1);

        var pcs     = +sc.stone_quantity;
        /* sc.stone_weight is TOTAL weight for this entry — display as-is, never divide by pcs */
        var totalWt = (+sc.stone_weight).toFixed(3) + ' ct';

        html += '<div class="gpd-drow' + (rowIndex === 0 ? ' gpd-drow-first' : '') + '">'
          + '<span class="gpd-drow-shape">' + pricingTitle + '</span>'
          + '<span class="gpd-drow-pcs">' + pcs + ' Diamond' + (pcs > 1 ? 's' : '') + '</span>'
          + '<span class="gpd-drow-weight">' + totalWt + '</span>'
          + '</div>';

        rowIndex++;
      }
    }

    var diamondBox  = document.getElementById('gpd-diamond-box');
    var diamondRows = document.getElementById('gpd-diamond-rows');

    if (hasDiamonds) {
      diamondRows.innerHTML = html;
      diamondBox.style.display = '';
    } else {
      diamondBox.style.display = 'none';
    }

    /* ---------- GOLD / METAL DETAILS ---------- */
    var metalType   = cfg.metal_type   || '';
    var purity      = cfg.purity       || '';
    var metalWeight = cfg.metal_weight || '';
    var goldColor   = cfg.gold_color   || cfg.metal_color || 'Yellow Gold';
    var karat       = purity;

    if (metalType.toLowerCase() === 'silver')   karat = '925';
    if (metalType.toLowerCase() === 'platinum') karat = '950';

    var goldRows = ''
      + '<tr class="gpd-row"><td class="gpd-col-label">Weight</td>'
      + '<td class="gpd-col-value">' + parseFloat(metalWeight).toFixed(3) + ' gm</td></tr>'
      + '<tr class="gpd-row"><td class="gpd-col-label">Karat</td>'
      + '<td class="gpd-col-value">' + karat + '</td></tr>'
      + '<tr class="gpd-row"><td class="gpd-col-label">Color</td>'
      + '<td class="gpd-col-value">' + goldColor + '</td></tr>';

    document.getElementById('gpd-gold-table').querySelector('tbody').innerHTML = goldRows;
    document.getElementById('gpd-gold-box').style.display = metalType ? '' : 'none';
  }

  /* ── Helper: get pricing title for a stone config entry ──
     Uses stone_weight / stone_quantity ONLY for slab range lookup — never for display */
  function gpdFetchTitle(sc) {
    var pw = (+sc.stone_weight) / (+sc.stone_quantity); // per-piece weight for slab lookup only
    for (var i = 0; i < gpdStonePricings.length; i++) {
      var p = gpdStonePricings[i];
      if (p.id !== sc.pricing_id) continue;
      for (var j = 0; j < p.slabs.length; j++) {
        var s = p.slabs[j];
        if (pw >= s.from_weight && pw <= s.to_weight) return p.title;
      }
    }
    return null;
  }
</script>

<style>
  #gpd-container {
    margin-top:20px;
    font-family: 'Inter', sans-serif;
    width: 100%;
    box-sizing: border-box;
    color: #28365B;
  }

  /* Description */
  .gpd-description {
    font-size: 13px;
    line-height: 1.65;
    color: #28365B;
    margin: 0 0 16px 0;
    font-weight: 400;
  }

  /* ── Static box ── */
  .gpd-box {
    background: #F5F6F8;
    border-radius: 8px;
    padding: 14px 16px 12px 16px;
    margin-bottom: 12px;
    box-sizing: border-box;
  }

  /* Header row: title left, column labels right aligned with data columns */
  .gpd-box-header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }

  .gpd-box-title {
    font-size: 13px;
    font-weight: 700;
    color: #28365B;
  }

  .gpd-box-header-cols {
    display: flex;
    min-width: 55%;
  }

  .gpd-accordion-title {
    font-size: 15px;
    padding: 2px;
    font-weight: 600;
    color: #28365B;
    letter-spacing: 0.01em;
  }

  .gpd-th {
    flex: 1;
    font-size: 12px;
    font-weight: 500;
    color: rgba(40,54,91,0.55);
    text-align: right;
  }

  /* Divider */
  .gpd-box-divider {
    width: 100%;
    height: 0.5px;
    background: rgba(40,54,91,0.2);
    margin-bottom: 2px;
  }

  /* ── Diamond data rows ── */
  .gpd-drow {
    display: flex;
    align-items: center;
    padding: 9px 0;
    border-top: 0.5px solid rgba(40,54,91,0.08);
    font-size: 13px;
    color: #28365B;
  }

  .gpd-drow-first {
    border-top: none;
  }

  /* Shape label takes left ~45%, matches title column */
  .gpd-drow-shape {
    flex: 1;
    font-weight: 500;
    color: #28365B;
  }

  /* Pcs + weight share the right 55%, mirroring header cols */
  .gpd-drow-pcs {
    flex: 1;
    text-align: right;
    font-weight: 400;
    color: #28365B;
  }

  .gpd-drow-weight {
    flex: 1;
    text-align: right;
    font-weight: 400;
    color: #28365B;
  }

  /* ── Gold detail table ── */
  .gpd-detail-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .gpd-row td {
    padding: 7px 0;
    font-size: 13px;
    line-height: 1.5;
    color: #28365B;
    vertical-align: middle;
    border-top: 0.5px solid rgba(40,54,91,0.08);
  }

  .gpd-row:first-child td { border-top: none; }

  .gpd-col-label {
    width: 50%;
    font-weight: 500;
    color: rgba(40,54,91,0.65);
  }

  .gpd-col-value {
    width: 50%;
    text-align: right;
    font-weight: 600;
    color: #28365B;
  }
</style>
