{%- comment -%}
  Trust Icons Snippet
{%- endcomment -%}

<div class="trust-icons-section">
  <div class="trust-icons-wrapper">

    {% comment %} <div class="trust-promise-title">
      THE VAAMA PROMISE<span class="tm">TM</span>
    </div> {% endcomment %}
    <div class="trust-row">

      <div class="grid-column" onclick="openTrustPopup('popup-returns')">
        <img src="https://cdn.shopify.com/s/files/1/0634/8239/6854/files/30_day_Return_Icon_ca4395f2-548f-40dd-9036-51f3d912fa6c.svg?v=1772005448" alt="Returns">
        <div class="trust-icons-title">
          Easy 30-Day Return
        </div>
      </div>

      {% comment %} <div class="grid-column" onclick="openTrustPopup('popup-hallmarked')">
        <img src="https://cdn.shopify.com/s/files/1/0634/8239/6854/files/width_500.webp?v=1769515618" alt="BIS">
        <div class="trust-icons-title">
          BIS Hallmarked<br>Jewellery
        </div>
      </div> {% endcomment %}

      <div class="grid-column" onclick="openTrustPopup('popup-buyback')">
        <img src="https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Lifetime_Buyback_Icon_a4682c74-08a9-4bb0-8c9e-40ad088a4a66.svg?v=1772005448" alt="Buyback">
        <div class="trust-icons-title">
          Lifetime Buyback
        </div>
      </div>

      <div class="grid-column" onclick="openTrustPopup('popup-exchange')">
        <img src="https://cdn.shopify.com/s/files/1/0634/8239/6854/files/lifetime_Exchange_Icon_1d34f14a-3828-4773-9663-024bdccbcffb.svg?v=1772005448" alt="Exchange">
        <div class="trust-icons-title">
          Lifetime Exchange
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Popups -->
<div id="popup-returns" class="trust-popup-overlay">
  <div class="trust-popup-content">
    <button class="trust-popup-close" onclick="closeTrustPopup('popup-returns')">×</button>
    <h3 class="trust-popup-title">30 Days Returns<br>No Questions Asked</h3>
    <div class="trust-popup-text">
      <p>If you're not completely satisfied, return within 30 days for a full refund. Easy & hassle-free process.</p>
    </div>
  </div>
</div>

{% comment %} <div id="popup-hallmarked" class="trust-popup-overlay">
  <div class="trust-popup-content">
    <button class="trust-popup-close" onclick="closeTrustPopup('popup-hallmarked')">×</button>
    <h3 class="trust-popup-title">BIS Hallmarked<br>Jewellery</h3>
    <div class="trust-popup-text">
      <p>Every piece is certified by the Bureau of Indian Standards, guaranteeing purity and authenticity.</p>
    </div>
  </div>
</div> {% endcomment %}

<div id="popup-buyback" class="trust-popup-overlay">
  <div class="trust-popup-content">
    <button class="trust-popup-close" onclick="closeTrustPopup('popup-buyback')">×</button>
    <h3 class="trust-popup-title">Lifetime Buyback</h3>
    <div class="trust-popup-text">
      <p>Sell back your jewellery anytime. We offer fair value for your pieces, ensuring your investment is protected.</p>
    </div>
  </div>
</div>

<div id="popup-exchange" class="trust-popup-overlay">
  <div class="trust-popup-content">
    <button class="trust-popup-close" onclick="closeTrustPopup('popup-exchange')">×</button>
    <h3 class="trust-popup-title">Lifetime Exchange</h3>
    <div class="trust-popup-text">
      <p>Upgrade or exchange your jewellery anytime. Keep your collection fresh with our lifetime exchange policy.</p>
    </div>
  </div>
</div>

<style>
/* Section */
.trust-icons-section {
  background: #fff;
  {% comment %} margin-top:10px; {% endcomment %}
  padding: 6px 0;
}

.trust-icons-wrapper {
  max-width: 1200px;
  margin: 0 auto;
}

.trust-header {
  text-align: center;
  font-size: 24px;
  margin-bottom: 28px;
  color: #333;
}

/* GRID – ALWAYS 4 IN ONE ROW */
.trust-row {
  display: flex;
  justify-content:space-between;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

/* ITEM */
.grid-column {
  text-align: center;
  cursor: pointer;
  padding: 8px 4px;
  transition: transform 0.25s ease;
}

.grid-column:hover {
  transform: translateY(-4px);
}

/* ICON */
.grid-column img {
  width: 56px;
  height: 56px;
  margin-bottom: 8px;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

/* TEXT */
.trust-icons-title {
  font-size: 14px;
  font-family:'Inter', SANS-SERIF;
  line-height: 1.25;
  color: #28365B;
  {% comment %} margin: 20px 0px; {% endcomment %}
}

/* POPUP OVERLAY */
.trust-popup-overlay {
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.7);
  z-index: 9999;
  justify-content: center;
  align-items: center;
}

/* POPUP CONTENT */
.trust-popup-content {
  background: white;
  padding: 30px;
  border-radius: 12px;
  max-width: 400px;
  width: 90%;
  position: relative;
    font-family:'Inter', SANS-SERIF;

  text-align: center;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

/* CLOSE BUTTON */
.trust-popup-close {
  position: absolute;
  top: 15px;
  right: 15px;
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  color: #333;
  line-height: 1;
  padding: 0;
  width: 30px;
  height: 30px;
}

.trust-popup-close:hover {
  color: #000;
}

/* POPUP TITLE */
.trust-popup-title {
  font-size: 20px;
  font-family:'Inter', SANS-SERIF;
  margin-bottom: 15px;
  color: #333;
  line-height: 1.3;
}

/* POPUP TEXT */
.trust-popup-text {
  font-size: 15px;
  line-height: 1.5;
  color: #555;
}

.trust-popup-text p {
  margin: 0;
}

/* Close popup when clicking outside */
.trust-popup-overlay {
  cursor: pointer;
}

.trust-popup-content {
  cursor: default;
}

/* TABLET */
@media (max-width: 768px) {
  .grid-column img {
    width: 52px;
    height: 52px;
  }

  .trust-icons-title {
    font-size: 12px;
  }
  
  .trust-popup-content {
    padding: 25px 20px;
    max-width: 350px;
  }
  
  .trust-popup-title {
    font-size: 18px;
  }
  
  .trust-popup-text {
    font-size: 14px;
  }
}

/* MOBILE – PERFECT FIT */
@media (max-width: 480px) {
  .trust-row {
    gap: 8px;
  }

  .grid-column img {
    width: 48px;
    height: 48px;
  }

  .trust-icons-title {
    font-size: 11px;
    line-height: 1.2;
  }
  
  .trust-popup-content {
    padding: 20px 15px;
    max-width: 300px;
  }
  
  .trust-popup-title {
    font-size: 16px;
    margin-bottom: 12px;
  }
  
  .trust-popup-text {
    font-size: 13px;
  }
}
.trust-promise-title {
  text-align: center;
  font-family: 'Inter', SANS-SERIF;
  font-size: 18px;
  letter-spacing: 2px;
  color: #111;
  margin-bottom: 24px;
  text-transform: uppercase;
}

.trust-promise-title .tm {
  font-size: 8px;
  vertical-align: super;
  margin-left: 2px;
}
@media (max-width: 480px) {
  .trust-promise-title {
    font-size: 15px;
    letter-spacing: 1.5px;
    margin-bottom: 18px;
  }
}

</style>

<script>
function openTrustPopup(id) {
  document.getElementById(id).style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeTrustPopup(id) {
  document.getElementById(id).style.display = 'none';
  document.body.style.overflow = 'auto';
}

// Close popup when clicking outside the content
document.addEventListener('DOMContentLoaded', function() {
  const popups = document.querySelectorAll('.trust-popup-overlay');
  popups.forEach(function(popup) {
    popup.addEventListener('click', function(e) {
      if (e.target === this) {
        closeTrustPopup(this.id);
      }
    });
  });
});

// Close with Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.querySelectorAll('.trust-popup-overlay').forEach(p => p.style.display = 'none');
    document.body.style.overflow = 'auto';
  }
});
</script>