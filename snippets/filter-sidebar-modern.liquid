{% comment %}
  filter-sidebar-modern.liquid
  Uses a SINGLE loop — each filter gets a unique data-index = forloop.index.
  Color filters render as swatches (open by default).
  Price filters render as dual-range slider + inputs.
  All other filters render as checkboxes (collapsed by default).

  Accepts:
  - results: {Object} Collection or Search object (required)
  - is_mobile: {Boolean} Whether this is the mobile drawer version (optional)
{% endcomment %}

<div class="vf-container">
  <facet-filters-form>
    <form id="FacetFiltersForm" class="vf-form">
      {%- if results.terms -%}
        <input type="hidden" name="q" value="{{ results.terms | escape }}">
        <input name="options[prefix]" type="hidden" value="last">
      {%- endif -%}

      <div class="vf-form-wrap">
        <header class="vf-header">
          <div class="vf-title">
            Filters
            {%- assign total_active_values = 0 -%}
            {%- for filter in results.filters -%}
              {%- assign total_active_values = total_active_values | plus: filter.active_values.size -%}
            {%- endfor -%}
            {%- if total_active_values > 0 -%}
              <span class="vf-active-badge">{{ total_active_values }}</span>
            {%- endif -%}
          </div>
          <div class="vf-header-actions">
            {%- if total_active_values > 0 -%}
              <facet-remove>
                <a href="{{ results.url | split: '?' | first }}" class="vf-clear-all">Clear All</a>
              </facet-remove>
            {%- endif -%}
          </div>
        </header>

        <div class="vf-groups">
          {%- for filter in results.filters -%}
            {%- assign filter_label_lower = filter.label | downcase -%}
            {%- assign is_color = false -%}
            {%- if filter_label_lower contains 'color' or filter_label_lower contains 'colour' -%}
              {%- assign is_color = true -%}
            {%- endif -%}

            {%- comment %} Color filters: open by default, swatch layout {%- endcomment %}
            {%- if is_color -%}
              <div class="vf-group js-filter" data-index="{{ forloop.index }}">
                <button type="button" class="vf-group__head js-filter-toggle">
                  <span class="vf-group__label">{{ filter.label }}</span>
                  <svg
                    class="vf-group__chevron"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </button>
                <div class="vf-group__body">
                  <div class="vf-color-grid">
                    {%- for value in filter.values -%}
                      <label class="vf-color-item">
                        <input
                          type="checkbox"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}
                            checked
                          {% endif %}
                          {% if value.count == 0 and value.active == false %}
                            disabled
                          {% endif %}
                        >
                        <span
                          class="vf-color-swatch {{ value.label | handle }}"
                          style="background-color: {{ value.value }};"
                          title="{{ value.label }}"
                        ></span>
                        <span class="vf-color-name">{{ value.label }}</span>
                        <span class="vf-color-count">({{ value.count }})</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              </div>

              {%- comment %} Price / numeric range filters {%- endcomment %}
            {%- elsif filter.type == 'price_range' or filter.type == 'number_range' -%}
              <div class="vf-group js-filter is-closed" data-index="{{ forloop.index }}">
                <button type="button" class="vf-group__head js-filter-toggle">
                  <span class="vf-group__label">{{ filter.label }}</span>
                  <svg
                    class="vf-group__chevron"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </button>
                <div class="vf-group__body">
                  <div class="vf-price-range">
                    {%- liquid
                      assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,SEK,TRY,UYU,VES,VND' | split: ','
                      assign uses_comma_decimals = false
                      if currencies_using_comma_decimals contains cart.currency.iso_code
                        assign uses_comma_decimals = true
                      endif
                    -%}
                    <price-range class="vf-price-inputs">
                      <div class="vf-range-slider">
                        <div class="vf-range-track"></div>
                        <input
                          type="range"
                          min="0"
                          max="{{ filter.range_max | divided_by: 100.0 | ceil }}"
                          value="{% if filter.min_value.value %}{{ filter.min_value.value | divided_by: 100.0 | ceil }}{% else %}0{% endif %}"
                          class="vf-range-input vf-range-min"
                          aria-label="Min price"
                        >
                        <input
                          type="range"
                          min="0"
                          max="{{ filter.range_max | divided_by: 100.0 | ceil }}"
                          value="{% if filter.max_value.value %}{{ filter.max_value.value | divided_by: 100.0 | ceil }}{% else %}{{ filter.range_max | divided_by: 100.0 | ceil }}{% endif %}"
                          class="vf-range-input vf-range-max"
                          aria-label="Max price"
                        >
                      </div>
                      <div class="vf-price-inputs-grid">
                        <div class="field">
                          <input
                            class="js-price-min field__input"
                            name="{{ filter.min_value.param_name }}"
                            id="Filter-{{ filter.label | escape }}-GTE"
                            {%- if filter.min_value.value -%}
                              {%- if uses_comma_decimals -%}
                                value="{{ filter.min_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                              {%- else -%}
                                value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                              {%- endif -%}
                            {%- endif -%}
                            type="number"
                            placeholder="0"
                            min="0"
                            max="{{ filter.range_max | divided_by: 100.0 | ceil }}"
                          >
                        </div>
                        <span class="vf-price-sep">—</span>
                        <div class="field">
                          <input
                            class="js-price-max field__input"
                            name="{{ filter.max_value.param_name }}"
                            id="Filter-{{ filter.label | escape }}-LTE"
                            {%- if filter.max_value.value -%}
                              {%- if uses_comma_decimals -%}
                                value="{{ filter.max_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' }}"
                              {%- else -%}
                                value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                              {%- endif -%}
                            {%- endif -%}
                            type="number"
                            min="0"
                            placeholder="{{ filter.range_max | divided_by: 100.0 | ceil }}"
                            max="{{ filter.range_max | divided_by: 100.0 | ceil }}"
                          >
                        </div>
                      </div>
                    </price-range>
                  </div>
                </div>
              </div>

              {%- comment %} All other filters: boolean, list — checkboxes, collapsed by default {%- endcomment %}
            {%- else -%}
              <div class="vf-group js-filter is-closed" data-index="{{ forloop.index }}">
                <button type="button" class="vf-group__head js-filter-toggle">
                  <span class="vf-group__label">{{ filter.label }}</span>
                  <svg
                    class="vf-group__chevron"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="6 9 12 15 18 9"></polyline>
                  </svg>
                </button>
                <div class="vf-group__body">
                  <ul class="vf-list">
                    {%- for value in filter.values -%}
                      <li>
                        <label class="vf-checkbox-label">
                          <input
                            type="checkbox"
                            name="{{ value.param_name }}"
                            value="{{ value.value }}"
                            {% if value.active %}
                              checked
                            {% endif %}
                            {% if value.count == 0 and value.active == false %}
                              disabled
                            {% endif %}
                            class="vf-checkbox"
                          >
                          <span class="vf-checkbox-box"></span>
                          <span class="vf-checkbox-text">
                            {{ value.label }}
                            <span class="vf-checkbox-count">({{ value.count }})</span>
                          </span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        <div class="vf-footer">
          <button type="submit" class="vf-apply-btn vf-apply-btn--footer">Apply Filters</button>
        </div>
      </div>
    </form>
  </facet-filters-form>
</div>

<script>
  (function () {
    function initFilterSidebar(container) {
      if (!container || container._vfInit) return;
      container._vfInit = true;

      // 1. Collapsible Panels
      container.addEventListener('click', (e) => {
        const toggle = e.target.closest('.js-filter-toggle');
        if (toggle) {
          const group = toggle.closest('.vf-group');
          if (group) group.classList.toggle('is-closed');
        }
      });

      // 2. Dual-Handle Price Slider
      container.querySelectorAll('.vf-range-slider').forEach((slider) => {
        const minInput = slider.querySelector('.vf-range-min');
        const maxInput = slider.querySelector('.vf-range-max');
        const track = slider.querySelector('.vf-range-track');
        const group = slider.closest('.vf-group');
        const priceInputMin = group ? group.querySelector('.js-price-min') : null;
        const priceInputMax = group ? group.querySelector('.js-price-max') : null;

        function updateTrack() {
          const min = parseFloat(minInput.value);
          const max = parseFloat(maxInput.value);
          const rangeMax = parseFloat(minInput.max);
          if (track) {
            track.style.left = (min / rangeMax) * 100 + '%';
            track.style.right = 100 - (max / rangeMax) * 100 + '%';
          }
        }

        if (minInput && maxInput) {
          minInput.addEventListener('input', () => {
            if (parseFloat(minInput.value) > parseFloat(maxInput.value)) {
              minInput.value = maxInput.value;
            }
            if (priceInputMin) priceInputMin.value = minInput.value;
            updateTrack();
          });

          maxInput.addEventListener('input', () => {
            if (parseFloat(maxInput.value) < parseFloat(minInput.value)) {
              maxInput.value = minInput.value;
            }
            if (priceInputMax) priceInputMax.value = maxInput.value;
            updateTrack();
          });

          updateTrack();
        }
      });

      // 3. Price text inputs sync to range slider
      container.querySelectorAll('.vf-price-inputs-grid').forEach((grid) => {
        const minText = grid.querySelector('.js-price-min');
        const maxText = grid.querySelector('.js-price-max');
        const group = grid.closest('.vf-group');
        const rangeMin = group ? group.querySelector('.vf-range-min') : null;
        const rangeMax = group ? group.querySelector('.vf-range-max') : null;

        if (minText && rangeMin) {
          minText.addEventListener('change', () => {
            rangeMin.value = minText.value;
            rangeMin.dispatchEvent(new Event('input'));
          });
        }
        if (maxText && rangeMax) {
          maxText.addEventListener('change', () => {
            rangeMax.value = maxText.value;
            rangeMax.dispatchEvent(new Event('input'));
          });
        }
      });
    }

    function run() {
      document.querySelectorAll('.vf-container').forEach(initFilterSidebar);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', run);
    } else {
      run();
    }
  })();
</script>
