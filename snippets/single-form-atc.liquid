  // Function to hide the "Powered by Partialy" span
  function hidePoweredBy() {
    const poweredByElements = document.querySelectorAll(".pp-powered-by");
    if (poweredByElements.length > 0) {
      poweredByElements.forEach(el => {
        el.style.display = "none";
      });
    }
  }

  // Run once after DOM is ready
  hidePoweredBy();

  // Also observe DOM changes (Partial.ly sometimes injects content after load)
  const observer = new MutationObserver(() => {
    hidePoweredBy();
  });

  // Watch the entire document for dynamically added nodes
  observer.observe(document.body, {
    childList: true,
    subtree: true
  });
  
