      function isColorInStock(color) {
        return availableSizesByColor[color] && availableSizesByColor[color].length > 0;
      }
      
      // Check if a specific color-size combination is available
      function isSizeAvailableForColor(color, size) {
        if (!availableSizesByColor[color]) return false;
        return availableSizesByColor[color].includes(size);
      }
      
      // Update size availability based on selected color
      function updateSizeAvailability(color) {
        const sizeOptions = document.querySelectorAll('.drawer-size-option');
        
        sizeOptions.forEach(sizeOption => {
          const sizeValue = sizeOption.querySelector('input').value;
          const sizeLabel = sizeOption.querySelector('label');
          const stockStatusSpan = sizeLabel.querySelector('.size-stock-status');
          
          if (color) {
            const isAvailable = isSizeAvailableForColor(color, sizeValue);
            const stockStatus = isAvailable ? 'In Stock' : 'Made to Order';
            
            // Update stock status text
            stockStatusSpan.textContent = stockStatus;
            
            // Update classes
            sizeLabel.classList.remove('size-in-stock', 'size-made-to-order');
            sizeOption.classList.remove('size-unavailable');
            
            if (isAvailable) {
              sizeLabel.classList.add('size-in-stock');
            } else {
              sizeLabel.classList.add('size-made-to-order');
            }
            
            // Enable/disable the size option
            sizeOption.querySelector('input').disabled = false;
          } else {
            // No color selected, show all sizes as available
            stockStatusSpan.textContent = 'Select Color';
            sizeLabel.classList.remove('size-in-stock', 'size-made-to-order');
            sizeOption.classList.remove('size-unavailable');
            sizeOption.querySelector('input').disabled = false;
          }
        });
