      // Open drawer function
      function openDrawer() {
        // Update drawer selections to match current selections
        if (selectedColor) {
          const drawerColorInput = drawer.querySelector(`input[name="drawer-color"][value="${selectedColor}"]`);
          if (drawerColorInput) {
            drawerColorInput.checked = true;
          }
        }
        
        if (selectedSize) {
          const drawerSizeInput = drawer.querySelector(`input[name="drawer-size"][value="${selectedSize}"]`);
          if (drawerSizeInput) {
            drawerSizeInput.checked = true;
          }
        }
        
