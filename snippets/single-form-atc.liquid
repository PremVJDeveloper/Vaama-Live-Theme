      // Function to update original variant inputs and trigger change events
      function updateVariantSelection(colorValue, sizeValue) {
        let shouldTriggerChange = false;
        
        // Update color if provided
        if (colorValue && colorValue !== selectedColor) {
          selectedColor = colorValue;
          const originalColorInput = document.querySelector(`.js-product-select-option--1 input[value="${colorValue}"]`);
          if (originalColorInput) {
            originalColorInput.checked = true;
            // Trigger change event using jQuery to match your theme
            if (typeof $ !== 'undefined') {
              $(originalColorInput).trigger('change');
            } else {
              const changeEvent = new Event('change', { bubbles: true });
              originalColorInput.dispatchEvent(changeEvent);
            }
            shouldTriggerChange = true;
            
            // Update size availability when color changes
            updateSizeAvailability(colorValue);
            // Update button text
            updateButtonText();
          }
        }
        
        // Update size if provided
        if (sizeValue && sizeValue !== selectedSize) {
          selectedSize = sizeValue;
          const originalSizeSelect = document.querySelector('.js-product-select-option--2 select');
          if (originalSizeSelect) {
            originalSizeSelect.value = sizeValue;
            // Trigger change event using jQuery to match your theme
            if (typeof $ !== 'undefined') {
              $(originalSizeSelect).trigger('change');
            } else {
              const changeEvent = new Event('change', { bubbles: true });
              originalSizeSelect.dispatchEvent(changeEvent);
            }
            shouldTriggerChange = true;
            // Update button text
            updateButtonText();
          }
