           position: fixed;
           top: 0;
           right: -100%;
           width: 460px;
           height: 100vh;
           background: #fff;
           box-shadow: -4px 0 10px rgba(0, 0, 0, 0.1);
           z-index: 9999;
           transition: right 0.3s ease-in-out;
           display: flex;
           flex-direction: column;
           border-left: 1px solid #ddd;
      }
     .Top {
         padding: 20px;
         background: #a8b6cd;
         border-radius: 10px;
      }
     .Top p {
         font-size: 20px;
      }
     .info-drawer.open {
         right: 0;
      }
     .drawer-content {
         flex: 1;
         overflow-y: auto;
         padding: 1.5rem;
      }
     .close-btn {
         position: absolute;
         top: 3.6rem;
         right: 2rem;
         background: none;
         border: none;
         font-size: 1.5rem;
         cursor: pointer;
      }
     .product-summary {
         display: flex;
         gap: 1rem;
         margin-bottom: 1rem;
         border: 1px solid #eee;
         padding: 0.75rem;
         border-radius: 8px;
         align-items: center;
         margin-top: 1rem;
    }
     .product-summary img {
         width: 60px;
         border-radius: 6px;
    }
     details {
         border-top: 1px solid #eee;
         padding: 0.75rem 0;
    }
    summary {
         font-weight: bold;
         cursor: pointer;
         font-size: 1rem;
         color: #28365b;
    }

    summary {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      cursor: pointer;
    }

    details>summary div>span.icon {
      width: 24px;
      height: 24px;
      transition: all 0.3s;
      display: inline-block;
      /* margin-left: auto; */
      transform: rotate(90deg);
      padding-left: 4px;
    }

    details[open]>summary div>span.icon {
      transform: rotate(270deg) !important;
    }

    details .table-responsive {
