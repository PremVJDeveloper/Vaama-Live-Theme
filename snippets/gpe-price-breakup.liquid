<!-- JavaScript -->
<script>
  document.getElementById('open-info-drawer').addEventListener('click', function () {
    document.getElementById('info-drawer').classList.add('open');
  });

  document.getElementById('close-info-drawer').addEventListener('click', function () {
    document.getElementById('info-drawer').classList.remove('open');
  });
  document.addEventListener('click', function(e) {
    const drawer = document.getElementById('info-drawer');
    const button = document.getElementById('open-info-drawer');
    if (!drawer.contains(e.target) && !button.contains(e.target)) {
      drawer.classList.remove('open');
    }
  });
</script>
