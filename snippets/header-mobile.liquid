}

body.template-index .bwp-header.header_2.sticky .header-mobile .field,
body.template-index .bwp-header.header_2.sticky .header-mobile .mobile-search-input,
body.template-index .bwp-header.header_2.sticky .header-mobile .mobile-search-input::placeholder,
body.template-index .bwp-header.header_2.sticky .header-mobile .search-labels,
body.template-index .bwp-header.header_2.sticky .header-mobile .search-labels span,
body.template-index .bwp-header.header_2.sticky .header-mobile .search-rotating-text span,
