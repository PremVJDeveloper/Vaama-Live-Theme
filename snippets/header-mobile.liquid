body.template-index .bwp-header.header_2.sticky .header-mobile svg,
body.template-index .bwp-header.header_2.sticky .header-mobile [class^="icon-"],
body.template-index .bwp-header.header_2.sticky .header-mobile [class*=" icon-"] {
  color: #000 !important;
  fill: #000 !important;
  stroke: #000 !important;
}

body.template-index .bwp-header.header_2.sticky .header-mobile .search-toggle {
