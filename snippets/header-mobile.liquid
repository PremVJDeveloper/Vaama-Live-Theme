<div class="header-mobile">
  <!-- Regular header (visible when not scrolled) -->
  <div class="header-top-mobile">
    <div class="mobile-container">
      <div class="header-center__inner">
        <div class="button-menu">
          <button class="js-menu-mobile btn menu-mobile__btn" type="button" style="margin-left: 30px">
            <i class="feather-menu"></i>
          </button>
        </div>
        <div class="header-logo" itemscope itemtype="http://schema.org/Organization">
          {%- if section.settings.logo -%}
            <a href="/" itemprop="url" class="header-logo__link">
              <img class="header-logo__img logo-home"
                src="{{ section.settings.logo | image_url:width:section.settings.logo.width,height:section.settings.logo.height }}" 
                srcset="{{ section.settings.logo | image_url:width:section.settings.logo.width,height:section.settings.logo.height }}"
                alt="{{ section.settings.logo.alt | default: shop.name }}"
                width="{{ section.settings.logo.width }}" height="{{ section.settings.logo.height }}"
                itemprop="logo">

              <img class="header-logo__img logo-main"
                src="https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Group_4_2.svg?v=1747038589"
                alt="{{ shop.name }}"
                width="150"
                height="auto"
                itemprop="logo">
            </a>
          {%- else -%}
            <a href="/" itemprop="url" class="header-logo__link header-logo__link--text">{{ shop.name }}</a>
          {%- endif -%}
        </div>
        <div class="header-right">
          {%- if section.settings.show_header_wishlist -%}
          <div class="wishlist-mobile">
            <a href="{{  section.settings.page_wishlist.url }}" title="wishlist" data-count-wishlist><i class="icon-wishlist"><span class="count"></span></i></a>
          </div>
          {%- endif -%}
          {%- if section.settings.show_header_user -%}
            <div class="header-account">
              <a class="login-account {% unless customer %}show-sotp-popup{% endunless %}" href="{{ routes.account_url }}">
                <i class="icon-account"></i>
              </a>
            </div>
          {%- endif -%}
          {%- if section.settings.show_header_cart -%}
            {% include 'header-cart' %}
          {%- endif -%}
        </div>
        
        <!-- Regular Search Bar (visible when not scrolled) -->
        {%- if section.settings.show_header_search -%}
        <style>
          /* Home page only */
