}
.view-similar__view-detail-link:hover { color: #b8860b; }
.view-detail__short { display: none; }

/* ── Misc ── */
.content-title-wishlist { color: #28365b; }
.product-single .product-single__metas .button-wishlist button { margin: 0; }
.product-card__content { margin-top: 0; }

/* ── Empty state ── */
.view-similar__empty {
  grid-column: 1 / -1;
  text-align: center;
  color: #888;
  padding: 40px 0;
  font-size: 13px;
    font-family:'Inter', sans-serif;

}

/* ── Trigger ── */
.view-similar__trigger-wrapper { 


}
.view-similar__trigger-btn { cursor: pointer; }

/* ── Body scroll-lock ── */
body.vs-scroll-locked {
  overflow: hidden !important;
  position: fixed;
  width: 100%;
}

/* ── Mobile only (<600px) ── */
@media (max-width: 599px) {
