}
</style>

<script>
(function () {
  'use strict';

  /* ── Scroll lock ── */
  var _savedScrollY = 0;
  function lockScroll() {
    _savedScrollY = window.pageYOffset || document.documentElement.scrollTop;
    document.body.style.top = '-' + _savedScrollY + 'px';
    document.body.classList.add('vs-scroll-locked');
  }
  function unlockScroll() {
    document.body.classList.remove('vs-scroll-locked');
    document.body.style.top = '';
    window.scrollTo(0, _savedScrollY);
  }

  /* ── Drawer controller ── */
  function ViewSimilarDrawer() {
    this.drawer      = document.querySelector('[data-view-similar-drawer]');
    this.overlay     = document.querySelector('[data-view-similar-overlay]');
    this.triggers    = document.querySelectorAll('[data-view-similar-trigger]');
    this.closes      = document.querySelectorAll('[data-view-similar-close]');
    this.loadingEl   = document.querySelector('[data-view-similar-loading]');
    this.bodyEl      = document.querySelector('[data-view-similar-body]');
    this._revealed   = false; /* deferred render flag — only pay cost once */
    this._touchStart = 0;

    if (!this.drawer) return;
    this._bindEvents();
  }

  ViewSimilarDrawer.prototype._bindEvents = function () {
    var self = this;
    var body = this.bodyEl;

    this.triggers.forEach(function (btn) {
      btn.addEventListener('click', function () { self.open(); });
    });
    this.closes.forEach(function (btn) {
      btn.addEventListener('click', function () { self.close(); });
    });
    if (this.overlay) {
      this.overlay.addEventListener('click', function () { self.close(); });
      this.overlay.addEventListener('touchmove', function (e) {
        e.preventDefault();
      }, { passive: false });
    }
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') self.close();
    });

    /* Scroll boundary guards */
    if (body) {
      body.addEventListener('wheel', function (e) {
        var atTop    = body.scrollTop === 0;
        var atBottom = body.scrollTop + body.clientHeight >= body.scrollHeight - 1;
        if ((atTop && e.deltaY < 0) || (atBottom && e.deltaY > 0)) e.preventDefault();
      }, { passive: false });

      body.addEventListener('touchstart', function (e) {
        self._touchStart = e.touches[0].clientY;
      }, { passive: true });

      body.addEventListener('touchmove', function (e) {
        var delta    = self._touchStart - e.touches[0].clientY;
        var atTop    = body.scrollTop === 0;
        var atBottom = body.scrollTop + body.clientHeight >= body.scrollHeight - 1;
        if ((atTop && delta < 0) || (atBottom && delta > 0)) e.preventDefault();
      }, { passive: false });
    }
  };

  ViewSimilarDrawer.prototype.open = function () {
    var self = this;
    lockScroll();

    this.drawer.classList.add('is-open');
    this.drawer.setAttribute('aria-hidden', 'false');
    if (this.overlay) {
      this.overlay.classList.add('is-visible');
      this.overlay.setAttribute('aria-hidden', 'false');
    }
    this.triggers.forEach(function (btn) { btn.setAttribute('aria-expanded', 'true'); });

    if (!this._revealed) {
      this._revealed = true;

      /* Step 1: show spinner */
      if (this.loadingEl) this.loadingEl.classList.add('is-active');

      /* Step 2: defer layout work until after animation settles */
      var revealDelay = 380;
      setTimeout(function () {
        if (self.bodyEl) self.bodyEl.classList.add('is-ready');

        /* Step 3: hide spinner after browser has painted */
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            if (self.loadingEl) self.loadingEl.classList.remove('is-active');
          });
        });
      }, revealDelay);
    }
  };

  ViewSimilarDrawer.prototype.close = function () {
    unlockScroll();
    this.drawer.classList.remove('is-open');
    this.drawer.setAttribute('aria-hidden', 'true');
    if (this.overlay) {
      this.overlay.classList.remove('is-visible');
      this.overlay.setAttribute('aria-hidden', 'true');
    }
    this.triggers.forEach(function (btn) { btn.setAttribute('aria-expanded', 'false'); });
  };

  /* Init */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { new ViewSimilarDrawer(); });
  } else {
    new ViewSimilarDrawer();
  }
})();
</script>
