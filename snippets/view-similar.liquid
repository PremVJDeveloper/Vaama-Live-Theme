}
.view-similar__drawer-body .wpb-variants-swatch {
  align-items: center;
}
.view-similar__drawer-body .wpb-variants-swatch .swatch-items label {
  width: 20px;
  height: 20px;
}
.view-similar__drawer-body .product-card__buttons,
.view-similar__drawer-body .content-button-mobile {
  display: none;
}

/* ── View Detail link ── */
.view-similar__view-detail { margin-top: -4px; }
.view-similar__view-detail-link {
  font-size: 11px;
    font-family:'Inter', sans-serif;

  color: #28365b;
  text-decoration: none;
