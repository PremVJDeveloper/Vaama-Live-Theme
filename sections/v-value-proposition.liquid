{%- style -%}
  .v-value-prop {
    background-color: {{ section.settings.bg_color | default: 'transparent' }};
    margin: 40px 0;

  }

  .v-value-prop__header {
    text-align: center;
    margin-bottom: 40px;
  }
  .v-value-prop__header .v-h2 {
    font-size: 1.75rem;
    color: #28365b;
  }
  .v-value-prop__grid {
    display: grid;
    grid-template-columns: repeat(4, max-content);
    align-items: flex-start;
    justify-content: center;
    gap: 150px;
  }

  .v-value-prop__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    /* padding: 20px; */
    position: relative;
    align-items: center;
    justify-content: center;
  }
  .v-value-prop__title {
    font-family: 'Inter', sans-serif !important;
    color: #28365b !important;

  }

  .v-value-prop__text {
    font-family: 'Inter', sans-serif !important;
    color: #28365b  !important;


  }
  /* Thin dividers between items on desktop */
  @media (min-width: 769px) {
    .v-value-prop__item:not(:last-child)::after {
      content: '';
      position: absolute;
      right: 0;
      top: 20%;
      height: 60%;
      width: 1px;
      background-color: var(--v-color-border);
      opacity: 0.5;
    }
    .v-value-prop__icon img {
    width: 48px;
    height: 48px;
  }

  }
  

@media (max-width: 768px) {
    .v-value-prop__grid {
      grid-template-columns: repeat(2, 1fr) !important;
        gap: 3px;
        margin: 0px 16px;    
      }
    .v-value-prop__item:nth-child(n+3)
         {
        margin-top: 14px; /* adjust as needed */
    }
    .v-value-prop__item::after {
      display: none;
    }
      .v-value-prop__header .v-h2 {
      font-size: 1.2rem;
  }
    .v-value-prop__icon img {
    width: 40px;
    height: 40px;
  }
  .v-value-prop__icon {
    width: 40px;
    height: 40px;
  }
  }

  .v-value-prop__icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--v-color-text);
  }

  .v-value-prop__icon svg {
    width: 100%;
    height: 100%;
    stroke-width: 1; /* Thin luxury feel */
  }

  .v-value-prop__title {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.5px !important;
    margin-bottom: 1px;
    color: var(--v-color-text);
    text-transform: capitalize;
  }

  .v-value-prop__text {
    font-size: 0.65rem;
    opacity: 0.6;
    line-height: 1.5;
    color: var(--v-color-text);
    margin: 0;
  }
{%- endstyle -%}

<section class="v-value-prop v-section-padding">
  <div class="v-container">
    {%- if section.settings.heading != blank -%}
      <div class="v-value-prop__header">
        <h2 class="v-h2">{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="v-value-prop__grid">
      {%- for block in section.blocks -%}
        <div class="v-value-prop__item" {{ block.shopify_attributes }}>
          <div class="v-value-prop__icon">
            {%- if block.settings.icon_svg != blank -%}
              {{ block.settings.icon_svg }}
            {%- elsif block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 100 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
              >
            {%- else -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v8M8 12h8"/>
              </svg>
            {%- endif -%}
          </div>
          <h3 class="v-value-prop__title">{{ block.settings.title }}</h3>
          <p class="v-value-prop__text">{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Luxury Value Proposition",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Why Customers Trust Vaama"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    }
  ],
  "blocks": [
    {
      "type": "proposition",
      "name": "Value Proposition",
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG (Optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon Image (Optional)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "30-Day Easy Returns"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Return or exchange within 30 days."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luxury Value Proposition",
      "blocks": [
        {
          "type": "proposition",
          "settings": { "title": "30-Day Easy Returns", "text": "Return or exchange within 30 days." }
        },
        { "type": "proposition", "settings": { "title": "Lifetime Buyback", "text": "Return or upgrade anytime." } },
        { "type": "proposition", "settings": { "title": "Lifetime Exchange", "text": "At 100% Market Value" } },
        {
          "type": "proposition",
          "settings": { "title": "Certified Purity", "text": "BIS Hallmarked & IGI/SGL Certified" }
        }
      ]
    }
  ]
}
{% endschema %}
