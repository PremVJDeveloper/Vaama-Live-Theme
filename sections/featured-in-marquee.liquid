{%- style -%}
  .featured-in-wrapper-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    overflow: hidden;
    width: 100%;
    position: relative;
  }

  .featured-in-wrapper-{{ section.id }} .featured-in-heading {
    font-size: {{ section.settings.heading_size }}px;
    text-align: center;
    margin: 0 0 32px;
    color: #28365B;
    font-weight: {{ section.settings.heading_weight }};
    letter-spacing: 0.5px;
    padding: 0 20px;
  }

  .featured-in-wrapper-{{ section.id }} .featured-in-subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    text-align: center;
    margin: 0 0 40px;
    color: {{ section.settings.subtitle_color }};
    font-weight: {{ section.settings.subtitle_weight }};
    padding: 0 20px;
  }

  .featured-in-wrapper-{{ section.id }} .marquee {
    display: flex;
    overflow: hidden;
    user-select: none;
    gap: {{ section.settings.logo_gap }}px;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      black 10%,
      black 90%,
      transparent
    );
    width: 100%;
  }

  .featured-in-wrapper-{{ section.id }} .marquee__group {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    gap: {{ section.settings.logo_gap }}px;
    min-width: auto;
    animation: scroll-{{ section.id }} {{ section.settings.speed }}s linear infinite;
    /* iOS optimizations */
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    perspective: 1000;
    -webkit-perspective: 1000;
  }

  .featured-in-wrapper-{{ section.id }} .marquee__group a {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease;
    text-decoration: none;
    flex-shrink: 0; /* Prevent logos from shrinking */
    margin: 0; /* Reset any margins */
    padding: 0; /* Reset any padding */
  }

  .featured-in-wrapper-{{ section.id }} .marquee__group a:hover {
    opacity: 0.7;
  }

  .featured-in-wrapper-{{ section.id }} .marquee__group img {
    max-width: {{ section.settings.logo_max_width }}px;
    max-height: {{ section.settings.logo_max_height }}px;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
    /* iOS optimizations */
    -webkit-transform: translateZ(0);
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  @keyframes scroll-{{ section.id }} {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* iOS-specific fixes
  @supports (-webkit-touch-callout: none) {
    .featured-in-wrapper-{{ section.id }} .marquee__group {
      gap: {{ section.settings.logo_gap }}px;
      will-change: transform;
    }
    
    .featured-in-wrapper-{{ section.id }} .marquee__group a {
      margin-right: 0;
    }
  } */

  /* Pause animation on hover */
  .featured-in-wrapper-{{ section.id }} .marquee:hover .marquee__group {
    animation-play-state: paused;
  }

  /* Mobile responsive */
  @media screen and (max-width: 768px) {
    .featured-in-wrapper-{{ section.id }} .featured-in-heading {
        margin: 0 0 26px;
        padding:0px;
      font-size: {{ section.settings.heading_size | times: 0.8 | round }}px;
    }
    
    .featured-in-wrapper-{{ section.id }} .featured-in-subtitle {
      font-size: {{ section.settings.subtitle_size | times: 0.8 | round }}px;
      margin-bottom: 30px;
    }
    
    .featured-in-wrapper-{{ section.id }} .marquee__group img {
      max-width: {{ section.settings.logo_max_width | times: 0.8 | round }}px;
      max-height: {{ section.settings.logo_max_height | times: 0.8 | round }}px;
    }
    
    .featured-in-wrapper-{{ section.id }} .marquee__group {
      gap: {{ section.settings.logo_gap | times: 0.6 | round }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .featured-in-wrapper-{{ section.id }} .featured-in-heading {
        margin: 0 0 32px;
        padding:0px;
      font-size: {{ section.settings.heading_size | times: 0.7 | round }}px;
    }
    
    .featured-in-wrapper-{{ section.id }} .featured-in-subtitle {
      font-size: {{ section.settings.subtitle_size | times: 0.7 | round }}px;
    }
    
    .featured-in-wrapper-{{ section.id }} .marquee__group img {
      max-width: {{ section.settings.logo_max_width | times: 0.7 | round }}px;
      max-height: {{ section.settings.logo_max_height | times: 0.7 | round }}px;
    }
    
    .featured-in-wrapper-{{ section.id }} .marquee__group {
      gap: {{ section.settings.logo_gap | times: 0.5 | round }}px;
    }
  }

  /* Prevent overflow issues */
  .featured-in-wrapper-{{ section.id }} * {
    box-sizing: border-box;
  }
{%- endstyle -%}

