opify.com\/s\/files\/1\/0634\/8239\/6854\/files\/diamond.png?v=1759859619","tag1_text":"Flat 30,000\/carat","tag2_icon_url":"https:\/\/cdn.shopify.com\/s\/files\/1\/0634\/8239\/6854\/files\/discount.png?v=1759855387","tag2_text":"Dhanteras Offer"},"blocks":{}}},"disabled":true,"settings":{}},"featured_custom_section_RKnjft":{"type":"featured-custom-section","blocks":{"column_CJjRRz":{"type":"_column","settings":{"width":100,"padding":"","margin":"","width_lap":100,"width_tab":100,"width_mobi":100},"blocks":{"text_block_iLza6p":{"type":"text-block","name":"Text block","settings":{"title":"<body>\n\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"Frequently asked questions about Vaama Jewellery's lab-grown diamonds, certification, quality standards, and customer policies.\">\n  <title>Frequently Asked Questions - Vaama Jewellery | Lab-Grown Diamond FAQs<\/title>\n\n<style> .faq-wrapper { max-width: 900px; margin: 0 auto; } .faq-title { text-align: center; color: #24335b; font-size: 2rem; font-weight: 600; margin-bottom: 40px; letter-spacing: -0.5px; } .main-faq-container { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; } .main-faq-toggle { background: #24335b; color: #ffffff; cursor: pointer; padding: 20px 24px; width: 100%; text-align: left; border: none; outline: none; font-size: 1.125rem; font-weight: 600; position: relative; transition: background-color 0.2s ease; display: flex; align-items: center; justify-content: space-between; } .main-faq-toggle:hover { background: #1a2847; } .main-faq-toggle:focus { outline: 2px solid #24335b; outline-offset: 2px; } .main-faq-toggle::after { content: '▼'; font-size: 1rem; transition: transform 0.3s ease; display: inline-block; } .main-faq-toggle.active::after { transform: rotate(180deg); } .main-faq-content { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; background: #ffffff; } .main-faq-content.active { max-height: 5000px; } .nested-faq-container { padding: 16px; } .faq-item { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 6px; margin-bottom: 10px; overflow: hidden; } .faq-toggle { background: #ffffff; color: #24335b; cursor: pointer; padding: 16px 20px; width: 100%; text-align: left; border: none; outline: none; font-size: 1rem; font-weight: 500; position: relative; transition: background-color 0.2s ease; display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; border-radius: 6px; } .faq-toggle:hover { background: #f9fafb; } .faq-toggle:focus { outline: 2px solid #24335b; outline-offset: -2px; } .faq-toggle.active { border-radius: 6px 6px 0 0; background: #f9fafb; } .faq-question { flex: 1; } .faq-toggle::after { content: '+'; font-size: 1.5rem; font-weight: 300; transition: transform 0.3s ease; display: inline-block; min-width: 20px; text-align: center; color: #24335b; line-height: 1; } .faq-toggle.active::after { content: '−'; } .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; background: #ffffff; color: #4b5563; line-height: 1.7; font-size: 0.95rem; border-top: 1px solid #e5e7eb; } .faq-content.active { max-height: 500px; padding: 16px 20px; } .faq-content p { margin: 0; } @media (max-width: 768px) { .faq-title { font-size: 1.5rem; margin-bottom: 30px; } .main-faq-toggle { padding: 16px 20px; font-size: 1rem; } .nested-faq-container { padding: 12px; } .faq-toggle { padding: 14px 16px; font-size: 0.95rem; } .faq-content { font-size: 0.9rem; } .faq-content.active { padding: 14px 16px; } } @media (prefers-reduced-motion: reduce) { * { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; } } <\/style>\n\n\n\n<main class=\"faq-wrapper\">\n  <h1 class=\"faq-title\">Frequently Asked Questions<\/h1>\n\n  <section class=\"main-faq-container\" itemscope itemtype=\"https:\/\/schema.org\/FAQPage\">\n\n    <button class=\"main-faq-toggle\" id=\"mainFaqToggle\" aria-expanded=\"false\" aria-controls=\"mainFaqContent\">\n      <span>Explore All FAQs<\/span>\n    <\/button>\n\n    <div class=\"main-faq-content\" id=\"mainFaqContent\">\n        <div class=\"nested-faq-container\">\n\n            <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https:\/\/schema.org\/Question\">\n              <button class=\"faq-toggle\" aria-expanded=\"false\">\n                <span class=\"faq-question\" itemprop=\"name\">Does Vaama Jewellery offer alternative metal options such as rose gold?<\/span>\n              <\/button>\n              <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https:\/\/schema.org\/Answer\">\n                <p itemprop=\"text\">Yes, we craft our jewellery in yellow gold, rose gold, and white gold to complement your personal style. Each metal brings its own character, rose gold offers warmth and romance, yellow gold provides classic elegance, while white gold delivers contemporary sophistication.<\/p>\n              <\/div>\n            <\/article>\n          \n            <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https:\/\/schema.org\/Question\">\n              <button class=\"faq-toggle\" aria-expanded=\"false\">\n                <span class=\"faq-question\" itemprop=\"name\">Is Vaama’s jewellery certified?<\/span>\n              <\/button>\n              <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https:\/\/schema.org\/Answer\">\n                <p itemprop=\"text\">Yes, all our jewellery comes with BIS Hallmarked certification and certified authenticity documentation. This ensures you receive complete transparency about your jewellery’s quality and characteristics. We believe in providing you with detailed information about your jewelry, so you can wear your Vaama piece with confidence knowing its true value and ethical origins.<\/p>\n              <\/div>\n            <\/article>\n          \n            <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https:\/\/schema.org\/Question\">\n              <button class=\"faq-toggle\" aria-expanded=\"false\">\n                <span class=\"faq-question\" itemprop=\"name\">How do I care for my pendant?<\/span>\n              <\/button>\n              <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https:\/\/schema.org\/Answer\">\n                <p itemprop=\"text\">Gentle care keeps your pendant looking brilliant for years to come. Clean it with warm water and mild soap using a soft brush, then dry with a lint-free cloth. Store your pendant separately to avoid scratching, and remove it before swimming or exercising.<\/p>\n              <\/div>\n            <\/article>\n          \n          <\/div>\n          \n    <\/div>\n\n  <\/section>\n<\/main>\n\n<script>\n \/* ✅ Keeping your same JS *\/\n const mainToggle = document.getElementById('mainFaqToggle');\n const mainContent = document.getElementById('mainFaqContent');\n const faqButtons = document.querySelectorAll('.faq-toggle');\n\n mainToggle.addEventListener('click', () => {\n   const isExpanded = mainToggle.getAttribute('aria-expanded') === 'true';\n   mainToggle.setAttribute('aria-expanded', !isExpanded);\n   mainToggle.classList.toggle('active');\n   mainContent.classList.toggle('active');\n });\n\n faqButtons.forEach(btn => {\n   btn.addEventListener('click', () => {\n     const isExpanded = btn.getAttribute('aria-expanded') === 'true';\n     btn.setAttribute('aria-expanded', !isExpanded);\n     btn.classList.toggle('active');\n     const faqAnswer = btn.nextElementSibling;\n     faqAnswer.classList.toggle('active');\n   });\n });\n<\/script>\n\n\n<\/body>","font":"--font-family-base","color":"#ffffff","font_size":16,"line_height":24,"letter_spacing":0,"font_weight":"300","align":"left","padding":"","margin":"","color_mobi":