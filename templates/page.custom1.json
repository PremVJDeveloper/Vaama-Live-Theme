    "featured_custom_section_LiUNb9": {
      "type": "featured-custom-section",
      "blocks": {
        "column_eg8g7b": {
          "type": "_column",
          "settings": {
            "width": 100,
            "padding": "",
            "margin": "",
            "width_lap": 100,
