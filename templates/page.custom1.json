          "blocks": {
            "text_block_KnVDML": {
              "type": "text-block",
              "settings": {
                "title": "<body>\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>3 Step Jewellery Customization Form</title>\n  <style>\n    .form-wrapper {\n      max-width: 1200px;\n      margin: 50px auto;\n      padding: 30px;\n      border: 0px solid #f2d1cf;\n      position: relative;\n    }\n\n    .step-tabs {\n      display: flex;\n      justify-content: space-between;\n      margin-bottom: 30px;\n      gap: 50px;\n    }\n\n    .step-tab {\n      flex: 1;\n      text-align: center;\n      padding: 10px;\n      border: none;\n      background-color: #dcdcdc;\n      color: #333;\n      cursor: pointer;\n      font-weight: 500;\n      border-right: 1px solid #fff;\n      transition: all 0.3s;\n    }\n\n    .step-tab.active {\n      background-color: #12203E;\n      color: white;\n    }\n\n    .step-tab:last-child {\n      border-right: none;\n    }\n\n    .step-content {\n      display: none;\n    }\n\n    .step-content.active {\n      display: block;\n    }\n\n    input, textarea, select {\n      width: 100%;\n      padding: 10px;\n      margin-bottom: 15px;\n      border: 1px solid #ccc;\n      border-radius: 4px;\n    }\n\n    .button-row {\n      display: flex;\n      justify-content: flex-end;\n      gap: 10px;\n    }\n\n    button {\n      background-color: #12203E;\n      color: white;\n      padding: 10px 20px;\n      border: none;\n      border-radius: 5px;\n      cursor: pointer;\n    }\n\n    button[disabled] {\n      background-color: #999;\n    }\n\n    #loader {\n      display: none;\n      text-align: center;\n      padding: 30px;\n    }\n\n    #loader div {\n      border: 5px solid #f3f3f3;\n      border-top: 5px solid #2d2d62;\n      border-radius: 50%;\n      width: 40px;\n      height: 40px;\n      animation: spin 1s linear infinite;\n      margin: 20px auto;\n    }\n\n    @keyframes spin {\n      0% { transform: rotate(0deg); }\n      100% { transform: rotate(360deg); }\n    }\n\n    @media (max-width: 600px) {\n      .step-tabs {\n        flex-direction: column;\n      }\n\n      .step-tab {\n        margin-bottom: 5px;\n      }\n\n      .button-row {\n        flex-direction: column;\n        align-items: stretch;\n      }\n\n      .step-content.active p {\n        color: black !important;\n      }\n\n      .step-content p {\n        color: black !important;\n      }\n\n      .form-wrapper p {\n        color: black;\n      }\n    }\n  </style>\n\n  <div class=\"form-wrapper\">\n    <div class=\"step-tabs\">\n      <div class=\"step-tab active\" data-step=\"1\">1. Tell Us Your Preferences</div>\n      <div class=\"step-tab\" data-step=\"2\">2. Share Your References</div>\n      <div class=\"step-tab\" data-step=\"3\">3. You’re Done!</div>\n    </div>\n\n    <!-- Step 1 -->\n    <div class=\"step-content active\" data-content=\"1\">\n      <input type=\"text\" id=\"name\" placeholder=\"Full Name\" required>\n      <input type=\"email\" id=\"email\" placeholder=\"Email Address\" required>\n      <input type=\"tel\" id=\"phone\" placeholder=\"Phone Number\" required>\n      <select id=\"type\">\n        <option disabled selected>Select Type of Jewellery</option>\n        <option>Rings</option>\n        <option>Bracelets</option>\n        <option>Pendants</option>\n        <option>Others</option>\n      </select>\n      <select id=\"metalType\">\n        <option disabled selected>Select Metal Type</option>\n        <option>14KT</option>\n        <option>18KT</option>\n      </select>\n      <select id=\"metalColour\">\n        <option disabled selected>Select Metal Colour</option>\n        <option>Yellow Gold</option>\n        <option>Rose Gold</option>\n        <option>White Gold</option>\n      </select>\n      <textarea id=\"description\" rows=\"4\" placeholder=\"Description\"></textarea>\n      <div class=\"button-row\">\n        <button onclick=\"nextStep(2)\">Next</button>\n      </div>\n    </div>\n\n    <!-- Step 2 -->\n    <div class=\"step-content\" data-content=\"2\">\n      <input type=\"text\" id=\"reference\" placeholder=\"Enter image / video URL or file name\">\n      <div class=\"button-row\">\n        <button onclick=\"prevStep(1)\">Back</button>\n        <button onclick=\"nextStep(3)\">Next</button>\n      </div>\n    </div>\n\n    <!-- Step 3 -->\n    <div class=\"step-content\" data-content=\"3\">\n      <h2>Thank You</h2>\n      <p>You are almost done<br><br>\n        Click submit to submit your request and we will get back to you shortly\n      </p>\n      <div class=\"button-row\">\n        <button onclick=\"prevStep(2)\">Back</button>\n        <button onclick=\"submitForm()\">Submit</button>\n      </div>\n    </div>\n\n    <!-- Loader -->\n    <div id=\"loader\">\n      <p style=\"font-weight: bold;\">Submitting your request...</p>\n      <div></div>\n    </div>\n  </div>\n\n  <script>\n    function nextStep(step) {\n      document.querySelectorAll('.step-content').forEach(s => s.classList.remove('active'));\n      document.querySelectorAll('.step-tab').forEach(t => t.classList.remove('active'));\n      document.querySelector(`.step-content[data-content=\"${step}\"]`).classList.add('active');\n      document.querySelector(`.step-tab[data-step=\"${step}\"]`).classList.add('active');\n    }\n\n    function prevStep(step) {\n      nextStep(step);\n    }\n\n    function submitForm() {\n      const data = {\n        name: document.getElementById('name').value,\n        email: document.getElementById('email').value,\n        phone: document.getElementById('phone').value,\n        type: document.getElementById('type').value,\n        metalType: document.getElementById('metalType').value,\n        metalColour: document.getElementById('metalColour').value,\n        description: document.getElementById('description').value,\n        reference: document.getElementById('reference').value\n      };\n\n      // Show loader\n      document.querySelectorAll('.step-content').forEach(s => s.classList.remove('active'));\n      document.getElementById('loader').style.display = 'block';\n\n      fetch('https://script.google.com/macros/s/AKfycbz8Q4xp4AG16OxU7EpjnjxtuVhl7fnAxfuG3toOFxAuuNq8fwbTgg5DvCSH1zRW1YyT/exec', {\n        method: 'POST',\n        mode: 'no-cors',\n        headers: {\n          'Content-Type': 'application/json'\n        },\n        body: JSON.stringify(data)\n      }).then(() => {\n        showThankYouMessage();\n      }).catch(() => {\n        alert(\"There was an error submitting the form.\");\n        document.getElementById('loader').style.display = 'none';\n      });\n    }\n\n    function showThankYouMessage() {\n      const wrapper = document.querySelector('.form-wrapper');\n      wrapper.innerHTML = `\n        <div style=\"text-align: center; padding: 40px;\">\n          <h2>Thank You!</h2>\n          <p>We’ve received your request.<br><br>\n          A member of our team will be in touch with you shortly to discuss your design and to guide you through the next steps.</p>\n        </div>\n      `;\n    }\n  </script>\n\n</body>",
