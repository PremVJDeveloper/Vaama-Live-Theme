stom_section_XVykjE":{"type":"featured-custom-section","blocks":{"column_9qGGmh":{"type":"_column","settings":{"width":100,"padding":"","margin":"","width_lap":100,"width_tab":100,"width_mobi":100},"blocks":{"text_block_acXbyz":{"type":"text-block","name":"Text block","settings":{"title":"<body>\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"Frequently asked questions about Vaama Jewellery's lab-grown diamonds, certification, quality standards, and customer policies.\">\n  <title>Frequently Asked Questions - Vaama Jewellery | Lab-Grown Diamond FAQs<\/title>\n\n  <style>\n    .faq-wrapper {\n      max-width: 900px;\n      margin: 0 auto;\n    }\n\n    .faq-title {\n      text-align: center;\n      color: #24335b;\n      font-size: 2rem;\n      font-weight: 600;\n      margin-bottom: 40px;\n      letter-spacing: -0.5px;\n    }\n\n    .main-faq-container {\n      background: #ffffff;\n      border: 1px solid #e5e7eb;\n      border-radius: 8px;\n      overflow: hidden;\n    }\n\n    .main-faq-toggle {\n      background: #24335b;\n      color: #ffffff;\n      cursor: pointer;\n      padding: 20px 24px;\n      width: 100%;\n      text-align: left;\n      border: none;\n      outline: none;\n      font-size: 1.125rem;\n      font-weight: 600;\n      position: relative;\n      transition: background-color 0.2s ease;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n    }\n\n    .main-faq-toggle:hover {\n      background: #1a2847;\n    }\n\n    .main-faq-toggle::after {\n      content: '▼';\n      font-size: 1rem;\n      transition: transform 0.3s ease;\n      display: inline-block;\n    }\n\n    .main-faq-toggle.active::after {\n      transform: rotate(180deg);\n    }\n\n    .main-faq-content {\n      max-height: 0;\n      overflow: hidden;\n      transition: max-height 0.4s ease;\n      background: #ffffff;\n    }\n\n    .main-faq-content.active {\n      max-height: 5000px;\n    }\n\n    .nested-faq-container {\n      padding: 16px;\n    }\n\n    .faq-item {\n      background: #ffffff;\n      border: 1px solid #e5e7eb;\n      border-radius: 6px;\n      margin-bottom: 10px;\n      overflow: hidden;\n    }\n\n    .faq-toggle {\n      background: #ffffff;\n      color: #24335b;\n      cursor: pointer;\n      padding: 16px 20px;\n      width: 100%;\n      text-align: left;\n      border: none;\n      outline: none;\n      font-size: 1rem;\n      font-weight: 500;\n      position: relative;\n      transition: background-color 0.2s ease;\n      display: flex;\n      align-items: flex-start;\n      justify-content: space-between;\n      gap: 12px;\n      border-radius: 6px;\n    }\n\n    .faq-toggle.active {\n      background: #f9fafb;\n    }\n\n    .faq-toggle::after {\n      content: '+';\n      font-size: 1.5rem;\n      font-weight: 300;\n      transition: transform 0.3s ease;\n      display: inline-block;\n      min-width: 20px;\n      text-align: center;\n      color: #24335b;\n      line-height: 1;\n    }\n\n    .faq-toggle.active::after {\n      content: '−';\n    }\n\n    .faq-content {\n      max-height: 0;\n      overflow: hidden;\n      transition: max-height 0.3s ease, padding 0.3s ease;\n      background: #ffffff;\n      color: #4b5563;\n      line-height: 1.7;\n      font-size: 0.95rem;\n      border-top: 1px solid #e5e7eb;\n    }\n\n    .faq-content.active {\n      max-height: 500px;\n      padding: 16px 20px;\n    }\n\n  <\/style>\n\n\n\n  <main class=\"faq-wrapper\">\n    <h1 class=\"faq-title\">Frequently Asked Questions<\/h1>\n\n    <section class=\"main-faq-container\" itemscope itemtype=\"https:\/\/schema.org\/FAQPage\">\n\n      <button class=\"main-faq-toggle\" id=\"mainFaqToggle\" aria-expanded=\"false\">\n        <span>Explore All FAQs<\/span>\n      <\/button>\n\n      <div class=\"main-faq-content\" id=\"mainFaqContent\">\n        <div class=\"nested-faq-container\">\n\n          <!-- FAQ 1 -->\n          <article class=\"faq-item\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\">How do I determine my ring size for online ordering?<\/span>\n            <\/button>\n            <div class=\"faq-content\">\n              <p>We provide a complete ring sizing guide to help you find your perfect fit at home. If you're between sizes, we recommend sizing up for comfort. You can also find the Ring Size Guide on our website for additional help.<\/p>\n            <\/div>\n          <\/article>\n\n          <!-- FAQ 2 -->\n          <article class=\"faq-item\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\">What are the 4Cs of lab diamonds?<\/span>\n            <\/button>\n            <div class=\"faq-content\">\n              <p>The 4Cs - Cut, Color, Clarity, and Carat, define a diamond's quality and beauty. Cut determines light performance and sparkle. Color indicates how colorless the stone is. Clarity measures purity and internal characteristics. Carat refers to the weight of the diamond.<\/p>\n            <\/div>\n          <\/article>\n\n          <!-- FAQ 3 -->\n          <article class=\"faq-item\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\">Can Vaama help me design a custom ring?<\/span>\n            <\/button>\n            <div class=\"faq-content\">\n              <p>Yes! We love helping you create a personalized piece. Visit our “Customize Your Design” page where you can share your ideas. We will guide you from the concept stage to the final masterpiece.<\/p>\n            <\/div>\n          <\/article>\n\n        <\/div>\n      <\/div>\n    <\/section>\n  <\/main>\n\n  <script>\n    const mainToggle = document.getElementById('mainFaqToggle');\n    const mainContent = document.getElementById('mainFaqContent');\n    const faqButtons = document.querySelectorAll('.faq-toggle');\n\n    mainToggle.addEventListener('click', () => {\n      mainToggle.classList.toggle('active');\n      mainContent.classList.toggle('active');\n    });\n\n    faqButtons.forEach(button => {\n      button.addEventListener('click', () => {\n        button.classList.toggle('active');\n        button.nextElementSibling.classList.toggle('active');\n      });\n    });\n  <\/script>\n\n\n<\/body>","font":"--font-family-base","color":"#ffffff","font_size":16,"line_height":24,"letter_spacing":0,"font_weight":"300","align":"left","padding":"","margin":"","color_mobi":"#ffffff","font_size_mobi":16,"line_height_mobi":24,"letter_spacing_mobi":0,"align_mobi":"left"},"blocks":{}}},"block_order":["text_block_acXbyz"]}},"block_order":["column_9qGGmh"],"name":"Custom Section","settings":{"max_width":"","fullwidth":false,"background_color":"","background_fixed":false,"background_size":"cover","background_pos":"center center","padding":"","margin":"","vertical_align":"top","image_loading":"lazy","rotation_unit":"minute","rotation_interval":1,"horizontal_align":"left"}}},"order":["breadcrumb","1770894185075bc8a3","main","featured_custom_section_XVykjE"]}