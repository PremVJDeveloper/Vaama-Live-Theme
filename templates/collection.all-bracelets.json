"https:\/\/cdn.shopify.com\/s\/files\/1\/0634\/8239\/6854\/files\/diamond.png?v=1759859619","tag1_text":"Flat 30,000\/carat","tag2_icon_url":"https:\/\/cdn.shopify.com\/s\/files\/1\/0634\/8239\/6854\/files\/discount.png?v=1759855387","tag2_text":"Dhanteras Offer"},"blocks":{}}},"disabled":true,"settings":{}},"featured_custom_section_eBNH8a":{"type":"featured-custom-section","blocks":{"column_VYkPVq":{"type":"_column","settings":{"width":100,"padding":"","margin":"","width_lap":100,"width_tab":100,"width_mobi":100},"blocks":{"text_block_8NhQ88":{"type":"text-block","name":"Text block","settings":{"title":"<body>\n\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"Frequently asked questions about Vaama Jewellery's lab-grown diamonds, certification, quality standards, and customer policies.\">\n  <title>Frequently Asked Questions - Vaama Jewellery<\/title>\n\n  <style>\n    .faq-wrapper { max-width: 900px; margin: 0 auto; }\n    .faq-title { text-align: center; color: #24335b; font-size: 2rem; font-weight: 600; margin-bottom: 40px; letter-spacing: -0.5px; }\n    .main-faq-container { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; }\n    .main-faq-toggle { background: #24335b; color: #ffffff; cursor: pointer; padding: 20px 24px; width: 100%; text-align: left; border: none; outline: none; font-size: 1.125rem; font-weight: 600; position: relative; transition: background-color 0.2s ease; display: flex; align-items: center; justify-content: space-between; }\n    .main-faq-toggle:hover { background: #1a2847; }\n    .main-faq-toggle.active::after { transform: rotate(180deg); }\n    .main-faq-toggle::after { content: '▼'; font-size: 1rem; transition: transform 0.3s ease; }\n    .main-faq-content { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; }\n    .main-faq-content.active { max-height: 5000px; }\n    .nested-faq-container { padding: 16px; }\n    .faq-item { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 6px; margin-bottom: 10px; overflow: hidden; }\n    .faq-toggle { background: #ffffff; color: #24335b; cursor: pointer; padding: 16px 20px; width: 100%; text-align: left; border: none; outline: none; font-size: 1rem; font-weight: 500; display: flex; justify-content: space-between; gap: 12px; border-radius: 6px; }\n    .faq-toggle:hover { background: #f9fafb; }\n    .faq-toggle::after { content: '+'; font-size: 1.5rem; font-weight: 300; transition: 0.3s; }\n    .faq-toggle.active::after { content: '−'; }\n    .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; background: #ffffff; color: #4b5563; line-height: 1.7; font-size: 0.95rem; border-top: 1px solid #e5e7eb; }\n    .faq-content.active { max-height: 500px; padding: 16px 20px; }\n    \n    @media (max-width: 768px) {\n      .faq-title { font-size: 1.5rem; margin-bottom: 30px; }\n      .main-faq-toggle { padding: 16px 20px; font-size: 1rem; }\n      .faq-toggle { padding: 14px 16px; font-size: 0.95rem; }\n      .faq-content.active { padding: 14px 16px; }\n    }\n  <\/style>\n\n\n\n<main class=\"faq-wrapper\">\n  <h1 class=\"faq-title\">Frequently Asked Questions<\/h1>\n\n  <section class=\"main-faq-container\" itemscope itemtype=\"https:\/\/schema.org\/FAQPage\">\n    <button class=\"main-faq-toggle\" id=\"mainFaqToggle\" aria-expanded=\"false\" aria-controls=\"mainFaqContent\">\n      Explore All FAQs\n    <\/button>\n\n    <div class=\"main-faq-content\" id=\"mainFaqContent\">\n      <div class=\"nested-faq-container\">\n\n        <!-- FAQ 1 -->\n        <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https:\/\/schema.org\/Question\">\n          <button class=\"faq-toggle\" aria-expanded=\"false\">\n            <span itemprop=\"name\">Can I buy only diamonds?<\/span>\n          <\/button>\n          <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https:\/\/schema.org\/Answer\">\n            <p itemprop=\"text\">Yes, visit our gifting section to explore loose diamonds and other gemstones. Whether you're looking to customize an existing design or create something entirely new, our collection of individual stones offers beautiful options.<\/p>\n          <\/div>\n        <\/article>\n\n        <!-- FAQ 2 -->\n        <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https:\/\/schema.org\/Question\">\n          <button class=\"faq-toggle\" aria-expanded=\"false\">\n            <span itemprop=\"name\">What makes Vaama diamonds exceptionally brilliant?<\/span>\n          <\/button>\n          <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https:\/\/schema.org\/Answer\">\n            <p itemprop=\"text\">Every Vaama ring features diamonds with our Triple Excellent Cut grade, which maximizes light reflection for unmatched sparkle. Combined with EF color grading and VVS clarity, your jewellery delivers exceptional radiance.<\/p>\n          <\/div>\n        <\/article>\n\n        <!-- FAQ 3 -->\n        <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https:\/\/schema.org\/Question\">\n          <button class=\"faq-toggle\" aria-expanded=\"false\">\n            <span itemprop=\"name\">What if my jewellery doesn't feel quite right after I receive it?<\/span>\n          <\/button>\n          <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https:\/\/schema.org\/Answer\">\n            <p itemprop=\"text\">We offer 15-day easy returns because we want you to absolutely love your jewellery. If it doesn't feel like “the one,” you can return your piece within 30 Days. Not applicable for customized jewellery.<\/p>\n          <\/div>\n        <\/article>\n\n      <\/div>\n    <\/div>\n  <\/section>\n<\/main>\n\n<script>\n  const mainToggle = document.getElementById('mainFaqToggle');\n  const mainContent = document.getElementById('mainFaqContent');\n  const faqButtons = document.querySelectorAll('.faq-toggle');\n\n  mainToggle.addEventListener('click', () => {\n    const open = mainToggle.getAttribute('aria-expanded') === 'true';\n    mainToggle.setAttribute('aria-expanded', !open);\n    mainToggle.classList.toggle('active');\n    mainContent.classList.toggle('active');\n  });\n\n  faqButtons.forEach(btn => {\n    btn.addEventListener('click', () => {\n      const open = btn.getAttribute('aria-expanded') === 'true';\n      btn.setAttribute('aria-expanded', !open);\n      btn.classList.toggle('active');\n      btn.nextElementSibling.classList.toggle('active');\n    });\n  });\n<\/script>\n\n\n<\/body>","font":"--font-family-base","color":"#ffffff","font_size":16,"line_height":24,"letter_spacing":0,"font_weight":"300","align":"left","padding":"","margin":"","color_mobi":"#ffffff","font_size_mobi":16,"line_height_mobi":24,"letter_spacing_mobi":0,"align_mobi":"left"},"blocks":{}}},"block_order":["text_block_8NhQ88"]}},"block_order":["column_VYkPVq"],"name":"Custom Section","settings":{"max_width":"","fullwidth":false,"background_color":"","background_fixed":false,"background_size":"cover","background_pos":"center center","padding":"","margin":"","vertical_align":"top","image_loading":"lazy","rotation_unit":"minute","rotation_interval":1,"horizontal_align":"left"}}},"order":["breadcrumb","1770891252dfeb552e","custom_collection_modern_kMENPF","main","featured_custom_section_eBNH8a"]}