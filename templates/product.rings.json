,"column1":4,"column2":3,"column3":2,"column4":1}},"featured_custom_section_DpHxMJ":{"type":"featured-custom-section","blocks":{"column_w8zKLM":{"type":"_column","settings":{"width":100,"padding":"","margin":"","width_lap":100,"width_tab":100,"width_mobi":100},"blocks":{"text_block_w4eaLL":{"type":"text-block","name":"Text block","settings":{"title":"<body>\n\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"Frequently asked questions about Vaama Jewellery's lab-grown diamonds, certification, quality standards, and customer policies.\">\n  <title>Frequently Asked Questions - Vaama Jewellery | Lab-Grown Diamond FAQs<\/title>\n\n<style> .faq-wrapper { max-width: 900px; margin: 0 auto; } .faq-title { text-align: center; color: #24335b; font-size: 2rem; font-weight: 600; margin-bottom: 40px; letter-spacing: -0.5px; } .main-faq-container { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; overflow: hidden; } .main-faq-toggle { background: #24335b; color: #ffffff; cursor: pointer; padding: 20px 24px; width: 100%; text-align: left; border: none; outline: none; font-size: 1.125rem; font-weight: 600; position: relative; transition: background-color 0.2s ease; display: flex; align-items: center; justify-content: space-between; } .main-faq-toggle:hover { background: #1a2847; } .main-faq-toggle:focus { outline: 2px solid #24335b; outline-offset: 2px; } .main-faq-toggle::after { content: '▼'; font-size: 1rem; transition: transform 0.3s ease; display: inline-block; } .main-faq-toggle.active::after { transform: rotate(180deg); } .main-faq-content { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; background: #ffffff; } .main-faq-content.active { max-height: 5000px; } .nested-faq-container { padding: 16px; } .faq-item { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 6px; margin-bottom: 10px; overflow: hidden; } .faq-toggle { background: #ffffff; color: #24335b; cursor: pointer; padding: 16px 20px; width: 100%; text-align: left; border: none; outline: none; font-size: 1rem; font-weight: 500; position: relative; transition: background-color 0.2s ease; display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; border-radius: 6px; } .faq-toggle:hover { background: #f9fafb; } .faq-toggle:focus { outline: 2px solid #24335b; outline-offset: -2px; } .faq-toggle.active { border-radius: 6px 6px 0 0; background: #f9fafb; } .faq-question { flex: 1; } .faq-toggle::after { content: '+'; font-size: 1.5rem; font-weight: 300; transition: transform 0.3s ease; display: inline-block; min-width: 20px; text-align: center; color: #24335b; line-height: 1; } .faq-toggle.active::after { content: '−'; } .faq-content { max-height: 0; overflow: hidden; transition: max-height 0.3s ease, padding 0.3s ease; background: #ffffff; color: #4b5563; line-height: 1.7; font-size: 0.95rem; border-top: 1px solid #e5e7eb; } .faq-content.active { max-height: 500px; padding: 16px 20px; } .faq-content p { margin: 0; } @media (max-width: 768px) { .faq-title { font-size: 1.5rem; margin-bottom: 30px; } .main-faq-toggle { padding: 16px 20px; font-size: 1rem; } .nested-faq-container { padding: 12px; } .faq-toggle { padding: 14px 16px; font-size: 0.95rem; } .faq-content { font-size: 0.9rem; } .faq-content.active { padding: 14px 16px; } } @media (prefers-reduced-motion: reduce) { * { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; } } <\/style>\n\n\n\n<main class=\"faq-wrapper\">\n  <h1 class=\"faq-title\">Frequently Asked Questions<\/h1>\n\n  <section class=\"main-faq-container\" itemscope itemtype=\"https:\/\/schema.org\/FAQPage\">\n\n    <button class=\"main-faq-toggle\" id=\"mainFaqToggle\" aria-expanded=\"false\" aria-controls=\"mainFaqContent\">\n    <span>Explore All FAQs<\/span>\n    <\/button>\n    \n    <div class=\"main-faq-content\" id=\"mainFaqContent\">\n    <div class=\"nested-faq-container\">\n    \n    <!-- ✅ FAQ 1 Updated -->\n    <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https:\/\/schema.org\/Question\">\n    <button class=\"faq-toggle\" aria-expanded=\"false\">\n    <span class=\"faq-question\" itemprop=\"name\">Why Choose Lab-Grown Diamonds for Your Ring?<\/span>\n    <\/button>\n    <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https:\/\/schema.org\/Answer\">\n    <p itemprop=\"text\">\n    Lab-grown diamonds offer the same brilliance, durability, and chemical composition as mined diamonds while respecting our planet's resources. For rings that symbolize lasting commitment, choosing lab-grown means your love story includes care for future generations, making your meaningful moment even more meaningful.\n    <\/p>\n    <\/div>\n    <\/article>\n    \n    <!-- ✅ FAQ 2 Updated -->\n    <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https:\/\/schema.org\/Question\">\n    <button class=\"faq-toggle\" aria-expanded=\"false\">\n    <span class=\"faq-question\" itemprop=\"name\">What Makes Vaama Rings Special?<\/span>\n    <\/button>\n    <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https:\/\/schema.org\/Answer\">\n    <p itemprop=\"text\">\n    Our rings are crafted by skilled experts who understand that your ring will be worn every day for years to come. Each ring is designed for both beauty and security, using techniques that protect your diamond while maximizing its brilliance. We balance elegance with practical durability, ensuring your ring remains as stunning as the day you first wore it.\n    <\/p>\n    <\/div>\n    <\/article>\n    \n    <\/div>\n    <\/div>\n    <\/section>\n<\/main>\n\n<script>\n \/* ✅ Keeping your same JS *\/\n const mainToggle = document.getElementById('mainFaqToggle');\n const mainContent = document.getElementById('mainFaqContent');\n const faqButtons = document.querySelectorAll('.faq-toggle');\n\n mainToggle.addEventListener('click', () => {\n   const isExpanded = mainToggle.getAttribute('aria-expanded') === 'true';\n   mainToggle.setAttribute('aria-expanded', !isExpanded);\n   mainToggle.classList.toggle('active');\n   mainContent.classList.toggle('active');\n });\n\n faqButtons.forEach(btn => {\n   btn.addEventListener('click', () => {\n     const isExpanded = btn.getAttribute('aria-expanded') === 'true';\n     btn.setAttribute('aria-expanded', !isExpanded);\n     btn.classList.toggle('active');\n     const faqAnswer = btn.nextElementSibling;\n     faqAnswer.classList.toggle('active');\n   });\n });\n<\/script>\n\n\n<\/body>","font":"--font-family-base","color":"#ffffff","font_size":16,"line_height":24,"letter_spacing":0,"font_weight":"300","align":"left","padding":"","margin":"","color_mobi":"#ffffff","font_size_mobi":16,"line_height_mobi":24,"letter_spacing_mobi":0,"align_mobi":"left"},"blocks":{}}},"block_order":["text_block_w4eaLL"]}},"block_order":["column_w8zKLM"],"name":"Custom Section","settings":{"max_width":"","fullwidth":false,"background_color":"","background_fixed":false,"background_size":"cover","background_pos":"center center","padding":"","margin":"","vertical_align":"top","image_loading":"lazy","rotation_unit":"minute","rotation_interval":1,"horizontal_align":"left"}}},"order":["breadcrumb","product-template","buy-together","1745389569ca352f5b","product-tab","product-recommendations","recently-viewed","featured_custom_section_DpHxMJ"]}