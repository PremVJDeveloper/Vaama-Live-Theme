            "text_block_dQBnPx": {
              "type": "text-block",
              "settings": {
                "title": "<body>\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Vaama Jewellery Values</title>\n\n  <style>\n    .scroll-arrows {\n      display: none;\n    }\n\n    .values-section {\n      background-color: #fff;\n      padding: 60px 20px;\n      text-align: center;\n      position: relative;\n      max-width: 100%;\n      background-image: url(\"https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Frame_4_11.png?v=1747224977\");\n      background-size: cover;\n    }\n\n    .values-section::before,\n    .values-section::after {\n      content: '';\n      position: absolute;\n      background-image: url('/mnt/data/fcf090bd-2c6b-4db5-ad50-fd85c87f8ef8.png');\n      background-repeat: no-repeat;\n      background-size: contain;\n      opacity: 0.08;\n      z-index: 0;\n    }\n\n    .values-section::before {\n      top: 20px;\n      left: 20px;\n      width: 100px;\n      height: 100px;\n    }\n\n    .values-section::after {\n      bottom: 20px;\n      right: 20px;\n      width: 100px;\n      height: 100px;\n    }\n\n    .values-section h2 {\n      font-size: 28px;\n      font-weight: 500;\n      margin-bottom: 40px;\n      color: #28365B;\n      position: relative;\n      z-index: 1;\n    }\n\n    .values-grid {\n      display: flex;\n      justify-content: center;\n      flex-wrap: wrap;\n      gap: 150px;\n      z-index: 1;\n      position: relative;\n    }\n\n    .value-item {\n      max-width: 180px;\n      text-align: center;\n    }\n\n    .value-item img {\n      width: 100px;\n      margin-bottom: 15px;\n    }\n\n    .value-item p {\n      margin: 0;\n      color: #28365B;\n      font-size: 20px;\n      line-height: 1.4;\n      font-family: mickir;\n    }\n\n    .values-section .note {\n      margin-top: 40px;\n      font-size: 18px;\n      color: #28365B;\n      max-width: 100%;\n      margin-left: auto;\n      margin-right: auto;\n      position: relative;\n      z-index: 1;\n    }\n\n    /* Mobile scroll styles */\n    @media (max-width: 600px) {\n      .values-grid {\n        flex-wrap: nowrap;\n        overflow-x: auto;\n        scroll-snap-type: x mandatory;\n        -webkit-overflow-scrolling: touch;\n        gap: 0;\n      }\n\n      .value-item {\n        flex: 0 0 100%;\n        max-width: 100%;\n        scroll-snap-align: center;\n        padding: 20px;\n        box-sizing: border-box;\n      }\n\n      .value-item img {\n        margin: 0 auto 15px;\n        display: block;\n      }\n\n      .values-section h2 {\n        font-size: 22px;\n      }\n\n      .scroll-arrows {\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        max-width: 100%;\n        margin: 10px auto 0;\n        position: relative;\n        z-index: 2;\n        padding: 0 20px;\n      }\n\n      .scroll-arrow {\n        background-color: #f0f0f0;\n        border: none;\n        font-size: 18px;\n        padding: 6px 10px;\n        border-radius: 50%;\n        cursor: pointer;\n        box-shadow: 0 1px 4px rgba(0, 0, 0, 0.1);\n      }\n\n      .scroll-arrow:active {\n        background-color: #ddd;\n      }\n.values-section {\n    background-image: url(\"https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Phone_version.png?v=1747488215\");\n background-size: cover;\n}\n    }\n  </style>\n\n  <section class=\"values-section\">\n    <h2>Values Reflected In Our Products</h2>\n\n    <div class=\"values-grid\" id=\"valuesSlider\">\n      <div class=\"value-item\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Sustainable_1.png?v=1746165304\" alt=\"Sustainable Luxury\">\n        <p>Sustainable<br>Luxury</p>\n      </div>\n\n      <div class=\"value-item\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Sustainable_3.png?v=1746165304\" alt=\"Uncompromising Quality\">\n        <p>Uncompromising<br>Quality</p>\n      </div>\n\n      <div class=\"value-item\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Sustainable_2.png?v=1746165304\" alt=\"Transparency & Trust\">\n        <p>Transparency &<br>Trust</p>\n      </div>\n    </div>\n\n    <!-- Arrows for mobile -->\n    <div class=\"scroll-arrows\">\n      <button class=\"scroll-arrow\" onclick=\"scrollSlider(-1)\">←</button>\n      <button class=\"scroll-arrow\" onclick=\"scrollSlider(1)\">→</button>\n    </div>\n\n    <p class=\"note\">\n      These values don’t just define who we are, they define what you can expect in every product of <strong>Vaama Jewellery</strong>\n    </p>\n  </section>\n\n  <script>\n    function scrollSlider(direction) {\n      const slider = document.getElementById('valuesSlider');\n      const scrollAmount = slider.clientWidth;\n      slider.scrollBy({ left: direction * scrollAmount, behavior: 'smooth' });\n    }\n  </script>\n\n</body>",
