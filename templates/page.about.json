              "settings": {
                "title": "<body>\n\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <meta name=\"description\" content=\"Frequently asked questions about Vaama Jewellery's lab-grown diamonds, certification, quality standards, and customer policies.\">\n  <title>Frequently Asked Questions - Vaama Jewellery | Lab-Grown Diamond FAQs</title>\n  <style>\n    .faq-wrapper {\n      max-width: 900px;\n      margin: 0 auto;\n    }\n\n    .faq-title {\n      text-align: center;\n      color: #24335b;\n      font-size: 2rem;\n      font-weight: 600;\n      margin-bottom: 40px;\n      letter-spacing: -0.5px;\n    }\n\n    .main-faq-container {\n      background: #ffffff;\n      border: 1px solid #e5e7eb;\n      border-radius: 8px;\n      overflow: hidden;\n    }\n\n    .main-faq-toggle {\n      background: #24335b;\n      color: #ffffff;\n      cursor: pointer;\n      padding: 20px 24px;\n      width: 100%;\n      text-align: left;\n      border: none;\n      outline: none;\n      font-size: 1.125rem;\n      font-weight: 600;\n      position: relative;\n      transition: background-color 0.2s ease;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n    }\n\n    .main-faq-toggle:hover {\n      background: #1a2847;\n    }\n\n    .main-faq-toggle:focus {\n      outline: 2px solid #24335b;\n      outline-offset: 2px;\n    }\n\n    .main-faq-toggle::after {\n      content: '▼';\n      font-size: 1rem;\n      transition: transform 0.3s ease;\n      display: inline-block;\n    }\n\n    .main-faq-toggle.active::after {\n      transform: rotate(180deg);\n    }\n\n    .main-faq-content {\n      max-height: 0;\n      overflow: hidden;\n      transition: max-height 0.4s ease;\n      background: #ffffff;\n    }\n\n    .main-faq-content.active {\n      max-height: 5000px;\n    }\n\n    .nested-faq-container {\n      padding: 16px;\n    }\n\n    .faq-item {\n      background: #ffffff;\n      border: 1px solid #e5e7eb;\n      border-radius: 6px;\n      margin-bottom: 10px;\n      overflow: hidden;\n    }\n\n    .faq-toggle {\n      background: #ffffff;\n      color: #24335b;\n      cursor: pointer;\n      padding: 16px 20px;\n      width: 100%;\n      text-align: left;\n      border: none;\n      outline: none;\n      font-size: 1rem;\n      font-weight: 500;\n      position: relative;\n      transition: background-color 0.2s ease;\n      display: flex;\n      align-items: flex-start;\n      justify-content: space-between;\n      gap: 12px;\n      border-radius: 6px;\n    }\n\n    .faq-toggle:hover {\n      background: #f9fafb;\n    }\n\n    .faq-toggle:focus {\n      outline: 2px solid #24335b;\n      outline-offset: -2px;\n    }\n\n    .faq-toggle.active {\n      border-radius: 6px 6px 0 0;\n      background: #f9fafb;\n    }\n\n    .faq-question {\n      flex: 1;\n    }\n\n    .faq-toggle::after {\n      content: '+';\n      font-size: 1.5rem;\n      font-weight: 300;\n      transition: transform 0.3s ease;\n      display: inline-block;\n      min-width: 20px;\n      text-align: center;\n      color: #24335b;\n      line-height: 1;\n    }\n\n    .faq-toggle.active::after {\n      content: '−';\n    }\n\n    .faq-content {\n      max-height: 0;\n      overflow: hidden;\n      transition: max-height 0.3s ease, padding 0.3s ease;\n      background: #ffffff;\n      color: #4b5563;\n      line-height: 1.7;\n      font-size: 0.95rem;\n      border-top: 1px solid #e5e7eb;\n    }\n\n    .faq-content.active {\n      max-height: 500px;\n      padding: 16px 20px;\n    }\n\n    .faq-content p {\n      margin: 0;\n    }\n\n    @media (max-width: 768px) {\n\n\n      .faq-title {\n        font-size: 1.5rem;\n        margin-bottom: 30px;\n      }\n\n      .main-faq-toggle {\n        padding: 16px 20px;\n        font-size: 1rem;\n      }\n\n      .nested-faq-container {\n        padding: 12px;\n      }\n\n      .faq-toggle {\n        padding: 14px 16px;\n        font-size: 0.95rem;\n      }\n\n      .faq-content {\n        font-size: 0.9rem;\n      }\n\n      .faq-content.active {\n        padding: 14px 16px;\n      }\n    }\n\n    @media (prefers-reduced-motion: reduce) {\n      * {\n        animation-duration: 0.01ms !important;\n        animation-iteration-count: 1 !important;\n        transition-duration: 0.01ms !important;\n      }\n    }\n  </style>\n\n\n  <main class=\"faq-wrapper\">\n    <h1 class=\"faq-title\">Frequently Asked Questions</h1>\n\n    <section class=\"main-faq-container\" itemscope itemtype=\"https://schema.org/FAQPage\">\n      <button class=\"main-faq-toggle\" id=\"mainFaqToggle\" aria-expanded=\"false\" aria-controls=\"mainFaqContent\">\n        <span>Explore All FAQs</span>\n      </button>\n      \n      <div class=\"main-faq-content\" id=\"mainFaqContent\">\n        <div class=\"nested-faq-container\">\n          \n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">Is a lab grown diamond a real diamond?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">Yes, lab grown diamonds are genuine diamonds with identical physical, chemical, and optical properties to mined diamonds. They're created using advanced technology that replicates the natural diamond formation process in controlled laboratory conditions. Both rate 10 on the Mohs hardness scale and possess the same brilliance, fire, and durability.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">Is it worth buying lab grown diamonds?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">Absolutely. Lab grown diamonds offer exceptional value by providing the same beauty and quality as mined diamonds at typically 30-40% less cost. This means you can invest in higher quality grades or larger carat weights within your budget. You're getting superior quality while making a more sustainable choice.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">How much is 1 carat lab grown diamond?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">The price of a 1-carat lab grown diamond varies based on the 4Cs - cut, color, clarity, and carat weight. We recommend scheduling a consultation to explore options that match your specific preferences and budget, ensuring you receive the best value for your investment.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">What are the 4Cs of lab diamonds?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">The 4Cs - Cut, Color, Clarity, and Carat, define a diamond's quality and beauty. Cut determines how light moves through the stone, creating that captivating sparkle. Color grades range from colorless (D) to faint yellow (Z+), while Clarity measures internal characteristics. Carat refers to weight.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">Can I buy only diamonds?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">Yes, visit our gifting section to explore loose diamonds and other gemstones. Whether you're looking to customize an existing design or create something entirely new, our collection of individual stones offers beautiful options.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">Is Vaama's jewellery certified?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">Yes, all our jewellery comes with BIS Hallmarked certification and certified authenticity documentation. This ensures you receive complete transparency about your jewellery's quality and characteristics. We believe in providing you with detailed information about your jewelry, so you can wear your Vaama piece with confidence knowing its true value and ethical origins.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">What makes Vaama diamonds exceptionally brilliant?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">Every Vaama ring features diamonds with our Triple Excellent Cut grade, which maximizes light reflection for unmatched sparkle. Combined with EF color grading for brilliant white perfection and VVS clarity for exceptional transparency, your jewellery delivers the kind of radiance that captures attention and creates lasting memories.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">What if my jewellery doesn't feel quite right after I receive it?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">We offer 15-day easy returns because we want you to absolutely love your jewellery. Whether it's sizing, style, or simply not feeling like \"the one,\" you can return your piece within 30 Days. This gives you time to live with your ring and ensure it truly becomes part of your story. This is not applicable on customized jewellery.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">How does Vaama ensure consistent quality across all designs?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">The Vaama Promise applies to every piece of jewellery we create - EF color diamonds, VVS clarity, and Triple Excellent cuts are our non-negotiable standards. Whether you choose a classic solitaire or an intricate vintage-inspired design, you receive the same exceptional quality that defines our commitment to excellence.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">How to Properly Store Your Jewellery?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">Proper storage protects your earrings and extends their beauty for years to come. Store each pair in individual soft pouches or lined compartments to prevent scratching and tangling. Keep them away from humidity and direct sunlight, which can affect metal finishes over time. For earrings with gemstone accents, avoid contact with other jewelry pieces. Consider a dedicated jewelry box with separate sections, and always ensure earrings are completely dry before storing to prevent tarnishing.</p>\n            </div>\n          </article>\n\n          <article class=\"faq-item\" itemscope itemprop=\"mainEntity\" itemtype=\"https://schema.org/Question\">\n            <button class=\"faq-toggle\" aria-expanded=\"false\">\n              <span class=\"faq-question\" itemprop=\"name\">Can You Wear Lab-Grown Diamond Jewellery Everyday?</span>\n            </button>\n            <div class=\"faq-content\" itemscope itemprop=\"acceptedAnswer\" itemtype=\"https://schema.org/Answer\">\n              <p itemprop=\"text\">Absolutely. Lab-grown diamonds possess the same durability and hardness as mined diamonds, making them perfect for daily wear. Your Vaama earrings are crafted with secure settings and quality metals that withstand regular use while maintaining their brilliance. With proper care, your lab-grown diamond earrings will continue sparkling beautifully through all your everyday moments.</p>\n            </div>\n          </article>\n\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <script>\n    const mainToggle = document.getElementById('mainFaqToggle');\n    const mainContent = document.getElementById('mainFaqContent');\n    const faqButtons = document.querySelectorAll('.faq-toggle');\n\n    mainToggle.addEventListener('click', () => {\n      const isExpanded = mainToggle.getAttribute('aria-expanded') === 'true';\n      mainToggle.setAttribute('aria-expanded', !isExpanded);\n      mainToggle.classList.toggle('active');\n      mainContent.classList.toggle('active');\n    });\n\n    faqButtons.forEach(btn => {\n      btn.addEventListener('click', () => {\n        const isExpanded = btn.getAttribute('aria-expanded') === 'true';\n        btn.setAttribute('aria-expanded', !isExpanded);\n        btn.classList.toggle('active');\n        const faqAnswer = btn.nextElementSibling;\n        faqAnswer.classList.toggle('active');\n      });\n    });\n  </script>\n\n</body>",
