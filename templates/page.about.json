            "text_block_neQh8F": {
              "type": "text-block",
              "settings": {
                "title": "<body>\n\n\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Our Team</title>\n  <style>\n \n\n    .team-section {\n      padding: 60px 20px;\n      text-align: center;\n      max-width: 100%;\n      margin: auto;\n     background-color: #1e1e2f;\n    }\n\n    .team-section h2 {\n      font-size: 28px;\n      font-weight: 500;\n      margin-bottom: 8px;\n      display: inline-block;\n      padding-bottom: 4px;\n     color: #ffffff;\n    }\n\n    .team-section p {\n      font-size: 16px;\n      color: #ccc;\n      margin-bottom: 40px;\n    }\n\n    .team-grid {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n      gap: 30px;\n      justify-items: center;\n    }\n\n    .team-card {\n      background: #2d2d3a;\n      border-radius: 15px;\n      padding: 20px;\n      max-width: 400px;\n      box-shadow: 0 4px 20px rgba(0,0,0,0.2);\n    }\n\n    .team-card img {\n      width: 100%;\n      border-radius: 12px;\n      object-fit: cover;\n      margin-bottom: 15px;\n    }\n\n    .team-card h4 {\n      margin: 0;\n      font-size: 18px;\n      font-weight: 600;\n      color: #fff;\n    }\n\n    .team-card p {\n      margin: 5px 0 0;\n      font-size: 14px;\n      color: #aaa;\n    }\n\n    @media (max-width: 768px) {\n      .team-section h2 {\n        font-size: 24px;\n      }\n\n      .team-section p {\n        font-size: 14px;\n      }\n    }\n  </style>\n\n\n\n  <section class=\"team-section\">\n    <h2>The Faces Behind Vaama Jewellery</h2>\n    <p>The hearts and hands behind every meaningful sparkle</p>\n\n    <div class=\"team-grid\">\n      <div class=\"team-card\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Akshat.png?v=1747486079\" alt=\"Akshat Shah\">\n        <h4>Akshat Shah</h4>\n        <p>Founder</p>\n      </div>\n\n      <div class=\"team-card\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Tejas.png?v=1747486079\" alt=\"Tejas Shah\">\n        <h4>Tejas Shah</h4>\n        <p>Co-Founder</p>\n      </div>\n\n      <div class=\"team-card\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Rajul.png?v=1747486079\" alt=\"Rajul Shah\">\n        <h4>Rajul Shah</h4>\n        <p>Head of Packaging and Logistics</p>\n      </div>\n    </div>\n  </section>\n\n\n</body>",
