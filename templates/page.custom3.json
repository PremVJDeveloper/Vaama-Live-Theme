    @media (max-width: 768px) {\n     #shopify-section-template--18059827544246__featured_custom_section_DRrfLd  .hero-section {\n        padding: 20px;\n        justify-content: center;\n        text-align: center;\n      }\n#shopify-section-template--18059827544246__featured_custom_section_DRrfLd  .glass-container h1 {\n     font-size: 28px;\n    margin-bottom: 12px;\n    text-align: center;\n    color: white;\n    }\n     #shopify-section-template--18059827544246__featured_custom_section_DRrfLd .glass-container {\n        width: 100%;\n      }\n    #shopify-section-template--18059827544246__featured_custom_section_DRrfLd  .hero-section {\n        background: url('https://cdn.shopify.com/s/files/1/0634/8239/6854/files/Diamond_Information_page_1.png?v=1748934327') no-repeat center center / auto;\n        height: 550px;\n        display: flex;\n        vertical-align: top;\n        align-items: flex-start;\n        padding: 0 5%;\n        position: relative;\n        padding-top: 30px;\n    }    \n#shopify-section-template--18059827544246__featured_custom_section_DRrfLd  .glass-container button {\n    padding: 8px 16px;\n    background-color: rgb(255 255 255 / 100%) !important;\n    border: 1px solid rgba(255, 255, 255, 0.4);\n    color: #28365a !important;\n    border-radius: 20px;\n    cursor: pointer;\n    font-size: 0.9rem;\n    backdrop-filter: blur(4px);\n    transition: background 0.3s;\n    font-family: mickir;\n}\n}\n  </style>\n\n\n\n  <section class=\"hero-section\">\n    <div class=\"glass-container\">\n      <h1>What We Offer at Vaama Jewellery</h1>\n      <p>We provide diamonds with VVS Clarity (Very Very Slightly Included). This ensures an eye-clean, flawless appearance, offering premium quality without visible imperfections. Higher clarity means greater transparency and brilliance, making the diamond look pristine and luxurious, a standard we uphold in every piece we create.</p>\n     <button><a href=\"https://vaama.co/collections/blush-collection\">Explore now</a></button>\n    </div>\n  </section>\n\n\n</body>",
